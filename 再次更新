class CorpusCleaner:
"""GPT系列预训练标准数据清洗，支持多语言过滤、去重、质量筛选，修复边界bug"""
def init(self, config: EasyDict, logger: logging.Logger):
self.config = config
self.logger = logger
self.min_text_length = config.min_text_length
self.max_text_length = config.max_text_length
self.support_languages = ["zh", "en", "ja", "ko"]
 
# 正则清洗规则
self.html_re = re.compile(r'<[^>]+>', re.S | re.IGNORECASE)
self.url_re = re.compile(r'https?://\S+|www.\S+|ftp://\S+', re.S | re.IGNORECASE)
self.email_re = re.compile(r'\w+@\w+.\w+', re.S | re.IGNORECASE)
self.phone_re = re.compile(r'1[3-9]\d{9}', re.S)
self.duplicate_punct_re = re.compile(r'([。！？，；：.!?,;])\1+', re.S)
self.whitespace_re = re.compile(r'\s+', re.S)
self.invalid_char_re = re.compile(r'[\x00-\x08\x0b\x0c\x0e-\x1f\x7f]', re.S)
 
# 过滤关键词
self.harmful_keywords = ["色情", "赌博", "毒品", "暴力", "反动", "诈骗", "非法", "违禁"]
self.ad_keywords = ["广告", "微信", "扫码", "关注", "公众号", "加微", "引流", "带货"]
 
def normalize_unicode(self, text: str) -> str:
"""全角半角归一化，修复特殊字符处理bug"""
text = text.replace('\u3000',' ').replace('\u00A0',' ').replace('\u200B','').replace('\u200E','').replace('\u200F','')
res = []
for c in text:
code = ord(c)
if 0xFF01 <= code <= 0xFF5E:
code -= 0xFEE0
res.append(chr(code))
return ''.join(res)
 
def clean_single_text(self, text: str) -> Tuple[bool, str]:
"""单条文本全流程清洗，统一异常处理"""
try:
# 基础归一化
text = self.normalize_unicode(text)
text = self.invalid_char_re.sub('', text)
text = self.html_re.sub('', text)
text = self.url_re.sub('', text)
text = self.email_re.sub('', text)
text = self.phone_re.sub('', text)
text = self.duplicate_punct_re.sub(r'\1', text)
text = self.whitespace_re.sub(' ', text)
text = text.strip()
 
# 长度过滤
if len(text) < self.min_text_length or len(text) > self.max_text_length:
return False, f"文本长度不符合要求：{len(text)}"
 
# 语言过滤
try:
lang = langdetect.detect(text)
if lang not in self.support_languages:
return False, f"非支持语言：{lang}"
except LangDetectException:
return False, "语言检测失败"
 
# 关键词过滤
for kw in self.harmful_keywords:
if kw in text:
return False, f"包含违规关键词：{kw}"
 
return True, text
except Exception as e:
return False, f"清洗异常：{str(e)}"
 
def deduplicate_corpus(self, texts: List[str]) -> List[str]:
"""精确去重+Simhash模糊去重双链路，修复大内存占用bug"""
# 精确去重
seen_hash = set()
unique_texts = []
for text in tqdm(texts, desc="精确去重"):
text_hash = hashlib.sha256(text.encode("utf-8")).hexdigest()
if text_hash not in seen_hash:
seen_hash.add(text_hash)
unique_texts.append(text)
self.logger.info(f"精确去重完成：原始{len(texts)}条 → 去重后{len(unique_texts)}条")
 
# 模糊去重，分批处理避免OOM
final_texts = []
simhash_index = SimhashIndex([], k=3)
batch_size = 10000
 
for batch_start in tqdm(range(0, len(unique_texts), batch_size), desc="模糊去重"):
batch_texts = unique_texts[batch_start:batch_start+batch_size]
for idx, text in enumerate(batch_texts):
global_idx = batch_start + idx
sim_hash = Simhash(text)
if not simhash_index.get_near_dups(sim_hash):
simhash_index.add(f"text_{global_idx}", sim_hash)
final_texts.append(text)
 
self.logger.info(f"模糊去重完成：原始{len(unique_texts)}条 → 最终{len(final_texts)}条")
return final_texts
 
def clean_full_corpus(self, texts: List[str]) -> List[str]:
"""全量语料清洗主流程，修复进程池泄漏bug"""
self.logger.info(f"开始全量语料清洗，总文本数：{len(texts)}")
 
# 多进程并行清洗
with Pool(max(1, self.config.physical_cpu_cores//2)) as pool:
results = list(tqdm(
pool.imap(self.clean_single_text, texts),
total=len(texts),
desc="语料清洗"
))
pool.close()
pool.join()
 
# 过滤有效文本
valid_texts = []
invalid_count = 0
for is_valid, cleaned_text in results:
if is_valid:
valid_texts.append(cleaned_text)
else:
invalid_count += 1
 
self.logger.info(f"语料清洗完成：有效文本{len(valid_texts)}条，无效文本{invalid_count}条")
 
# 去重
final_texts = self.deduplicate_corpus(valid_texts)
return final_texts
 
