beta2=0.95,
epsilon=1e-8,
grad_clip=nn.ClipGradByGlobalNorm(CONFIG.max_grad_norm) if CONFIG.enable_grad_clip else None
)
 
# EMA初始化
ema = EMA(model, CONFIG.ema_decay) if CONFIG.enable_ema else None
 
# 梯度噪声注入器
grad_noise_injector = GradientNoiseInjector(
eta=CONFIG.grad_noise_eta,
gamma=CONFIG.grad_noise_gamma
) if CONFIG.enable_grad_noise_injection else None
 
# 断点加载
global_step, start_epoch, best_val_ppl, is_warmup_completed = load_checkpoint(CONFIG, model, optimizer, scheduler, ema)
patience = 0
model.train()
 
# -------------------------- 7. 主训练循环 --------------------------
LOGGER.info("="*150)
LOGGER.info("第六步：开始预训练主循环")
LOGGER.info("="*150)
 
for epoch in range(start_epoch, CONFIG.max_epochs):
LOGGER.info(f"开始第{epoch+1}/{CONFIG.max_epochs}轮训练")
epoch_loss = 0.0
epoch_z_loss = 0.0
total_tokens_processed = 0
 
# 进度条
progress_bar = tqdm(
enumerate(train_loader),
total=len(train_loader),
desc=f"Epoch {epoch+1}/{CONFIG.max_epochs}",
unit="batch",
leave=True
)
 
for batch_idx, (x, y) in progress_bar:
# 跳过已训练的步数（断点续训）
if global_step > 0 and batch_idx < global_step * CONFIG.gradient_accumulation_steps % len(train_loader):
continue
 
# 前向传播
logits, z_loss = model(x)
 
# 交叉熵损失
ce_loss = F.cross_entropy(
logits.reshape([-1, tokenizer.vocab_size]),
y.reshape([-1]),
label_smoothing=CONFIG.label_smoothing
)
 
# R-Drop正则化
r_drop_loss_val = paddle.to_tensor(0.0)
if CONFIG.enable_r_drop and model.training:
logits2, _ = model(x)
r_drop_loss_val = r_drop_loss(logits, logits2, CONFIG.r_drop_alpha)
 
# 熵正则化
entropy_loss_val = paddle.to_tensor(0.0)
if CONFIG.enable_entropy_regularization:
probs = F.softmax(logits, axis=-1)
entropy = -paddle.sum(probs * paddle.log(probs + 1e-10), axis=-1).mean()
entropy_loss_val = -CONFIG.entropy_coeff * entropy
 
# 总损失
total_loss = (ce_loss + z_loss + r_drop_loss_val + entropy_loss_val) / CONFIG.gradient_accumulation_steps
 
# 反向传播
total_loss.backward()
 
# 梯度累积更新
if (batch_idx + 1) % CONFIG.gradient_accumulation_steps == 0:
# 梯度噪声注入
if grad_noise_injector is not None:
grad_noise_injector.inject(model.parameters(), global_step)
 
# 优化器步进
optimizer.step()
optimizer.clear_grad()
scheduler.step()
if ema is not None:
ema.update()
 
global_step += 1
current_lr = optimizer.get_lr()
tokens_per_step = CONFIG.batch_size_per_step * CONFIG.max_seq_len * CONFIG.gradient_accumulation_steps
total_tokens_processed += tokens_per_step
 
# 日志记录
if global_step % CONFIG.log_interval == 0:
train_ppl = np.exp(ce_loss.numpy()[0])
metrics = {
"lr": current_lr,
"ce_loss": ce_loss.numpy()[0].item(),
"z_loss": z_loss.numpy()[0].item(),
"r_drop_loss": r_drop_loss_val.numpy()[0].item(),
"entropy_loss": entropy_loss_val.numpy()[0].item(),
"total_loss": total_loss.numpy()[0].item() * CONFIG.gradient_accumulation_steps,
"train_ppl": train_ppl.item(),
"tokens_processed": total_tokens_processed
}
is_normal, _ = TRAIN_METRIC_MANAGER.log_metrics(global_step, epoch+1, metrics)
if not is_normal:
LOGGER.critical("数值异常，训练终止")
return
 
# 进度条更新
progress_bar.set_postfix({
"loss": f"{total_loss.numpy()[0] * CONFIG.gradient_accumulation_steps:.4f}",
"ppl": f"{train_ppl:.2f}",
"lr": f"{current_lr:.8f}"
})
 
# 验证与最优模型保存
if global_step % CONFIG.val_interval == 0:
LOGGER.info(f"第{global_step}步，开始验证集评估")
val_loss, val_ppl = evaluate(
model, val_loader, tokenizer.vocab_size,
ema, CONFIG.max_val_batches
)
val_metrics = {
"val_loss": val_loss.item(),
"val_ppl": val_ppl.item()
}
TRAIN_METRIC_MANAGER.log_metrics(global_step, epoch+1, val_metrics)
LOGGER.info(f"验证完成 | 验证损失：{val_loss:.4f} | 验证PPL：{val_ppl:.4f}")
 
# 判断是否为最优模型
is_best = val_ppl < best_val_ppl - CONFIG.early_stop_min_delta
if is_best:
best_val_ppl = val_ppl
patience = 0
else:
patience += 1
 
# 保存断点
save_checkpoint(
CONFIG, model, optimizer, scheduler, ema, tokenizer,
global_step, epoch+1, val_ppl, is_best=is_best
)
 
# 早停机制
if patience >= CONFIG.early_stop_patience:
LOGGER.info(f"早停机制触发，连续{CONFIG.early_stop_patience}次验证无提升，训练终止")
break
 
# 定时保存断点
if global_step % CONFIG.save_interval == 0:
save_checkpoint(
CONFIG, model, optimizer, scheduler, ema, tokenizer,
global_step, epoch+1, val_ppl if 'val_ppl' in locals() else float("inf"),
is_best=False
)
 
# 轮次结束日志
LOGGER.info(f"第{epoch+1}轮训练完成，平均损失：{epoch_loss/len(train_loader):.4f}")
 
# 早停终止
if patience >= CONFIG.early_stop_patience:
break
 
# -------------------------- 8. 训练完成：测试集最终评估 --------------------------
LOGGER.info("="*150)
LOGGER.info("第七步：训练完成，测试集最终评估")
LOGGER.info("="*150)
 
# 加载最优模型进行测试
best_checkpoint_path = os.path.join(CONFIG.checkpoint_dir, "best_checkpoint.pdparams")
if os.path.exists(best_checkpoint_path):
LOGGER.info("加载最优模型进行测试集评估")
best_checkpoint = paddle.load(best_checkpoint_path)
model.set_state_dict(best_checkpoint["model_state_dict"])
 
# 测试集评估
test_loss, test_ppl = evaluate(
model, test_loader, tokenizer.vocab_size,
ema=None, max_batches=CONFIG.max_test_batches
)
test_metrics = {
"test_loss": test_loss.item(),
"test_ppl": test_ppl.item(),
"total_train_steps": global_step,
"total_epochs": epoch+1
}
TEST_METRIC_MANAGER.log_metrics(global_step, epoch+1, test_metrics)
LOGGER.info(f"测试集最终评估完成 | 测试损失：{test_loss:.4f} | 测试PPL：{test_ppl:.4f}")
 
# -------------------------- 9. 保存最终模型 --------------------------
LOGGER.info("="*150)
LOGGER.info("第八步：保存最终预训练模型")
LOGGER.info("="*150)
 
# 保存纯模型权重（最终交付）
final_model_state = model.state_dict()
paddle.save(final_model_state, CONFIG.final_model_save_path)
LOGGER.info(f"最终模型保存完成，路径：{CONFIG.final_model_save_path}")
 
# 保存分词器配置，方便后续推理使用
tokenizer_config_path = os.path.join(CONFIG.tokenizer_dir, "tokenizer_config.json")
with open(tokenizer_config_path, "w", encoding="utf-8") as f:
json.dump({
"vocab_size": tokenizer.vocab_size,
"special_tokens": tokenizer.special_tokens,
"model_path": tokenizer.model_path,
"max_seq_len": CONFIG.max_seq_len
}, f, ensure_ascii=False, indent=2)
 
LOGGER.info("="*150)
LOGGER.info(f"预训练全流程完成！最终模型、最优模型、断点均已保存，测试集PPL：{test_ppl:.4f}")
LOGGER.info("="*150)
 
