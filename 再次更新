# ====================================== 4. 日志与指标管理（新增预热专属日志） ======================================
def setup_logger(config: EasyDict) -> logging.Logger:
    """工业级日志系统，全流程监控、异常捕获、轮转归档"""
    log_file = os.path.join(config.log_dir, "train_full.log")
    logger = logging.getLogger("gpt_sota_pretrain")
    logger.setLevel(logging.DEBUG)
    logger.propagate = False
    
    # 清空已有handler，修复日志重复打印bug
    if logger.handlers:
        logger.handlers.clear()
    
    # 日志格式
    log_format = logging.Formatter(
        "[%(asctime)s] [%(levelname)s] [%(module)s:%(lineno)d] %(message)s",
        datefmt="%Y-%m-%d %H:%M:%S"
    )
    
    # 控制台handler：INFO级别，实时进度
    console_handler = logging.StreamHandler()
    console_handler.setLevel(logging.INFO)
    console_handler.setFormatter(log_format)
    logger.addHandler(console_handler)
    
    # 文件handler：全量DEBUG日志，支持轮转，单文件200M，最多50个备份
    file_handler = RotatingFileHandler(
        log_file, maxBytes=200*1024*1024, backupCount=50, encoding="utf-8"
    )
    file_handler.setLevel(logging.DEBUG)
    file_handler.setFormatter(log_format)
    logger.addHandler(file_handler)
    
    # 启动日志
    logger.info("="*150)
    logger.info(f"SOTA大模型预训练启动时间：{datetime.now().strftime('%Y-%m-%d %H:%M:%S')}")
    logger.info(f"CPU环境：{config.physical_cpu_cores}核，MKL-DNN={'开启' if config.enable_mkldnn else '关闭'}")
    logger.info(f"多阶段预热：{'开启' if config.enable_multi_stage_warmup else '关闭'}")
    logger.info(f"全量配置参数：{json.dumps(dict(config), ensure_ascii=False, indent=2)}")
    logger.info("="*150)
    
    return logger

class MetricManager:
    """全维度指标管理，正则化项全监控、数值异常检测、历史回溯"""
    def __init__(self, metric_file: str, logger: logging.Logger, config: EasyDict):
        self.metric_file = metric_file
        self.logger = logger
        self.config = config
        self.metric_history = []
        self.best_val_ppl = float("inf")
        self.best_val_loss = float("inf")
        self.nan_inf_count = 0
        self.max_nan_inf_tolerance = 5
        
        # 初始化指标文件
        if not os.path.exists(metric_file):
            with open(metric_file, "w", encoding="utf-8") as f:
                f.write("")
        
        # 加载历史指标
        if config.enable_auto_resume and os.path.exists(metric_file):
            self._load_history()
    
    def _load_history(self):
        """加载历史指标，断点续训兼容"""
        try:
            with open(self.metric_file, "r", encoding="utf-8") as f:
                for line in f:
                    line = line.strip()
                    if line:
                        self.metric_history.append(json.loads(line))
            if self.metric_history:
                self.best_val_ppl = min([m.get("val_ppl", float("inf")) for m in self.metric_history])
                self.best_val_loss = min([m.get("val_loss", float("inf")) for m in self.metric_history])
                self.logger.info(f"历史指标加载完成，共{len(self.metric_history)}条记录，最优验证PPL：{self.best_val_ppl:.4f}")
        except Exception as e:
            self.logger.warning(f"历史指标加载失败：{str(e)}")
    
    def _check_nan_inf(self, metrics: Dict) -> bool:
        """NaN/Inf数值异常检测，训练崩溃防护"""
        if not self.config.enable_nan_inf_detection:
            return True
        
        for key, value in metrics.items():
            if isinstance(value, (int, float, np.number)):
                if np.isnan(value) or np.isinf(value):
                    self.nan_inf_count += 1
                    self.logger.error(f"数值异常检测：{key} 出现NaN/Inf，累计异常次数：{self.nan_inf_count}")
                    if self.nan_inf_count >= self.max_nan_inf_tolerance:
                        self.logger.critical(f"数值异常次数超过阈值，训练终止")
                        return False
        return True
    
    def log_metrics(self, step: int, epoch: int, metrics: Dict, is_warmup: bool = False) -> Tuple[bool, Dict]:
        """写入指标，异常检测，返回是否正常+处理后的指标"""
        # 数值异常检测
        is_normal = self._check_nan_inf(metrics)
        if not is_normal:
            return False, metrics
        
        # 补充元数据
        metric_data = {
            "timestamp": datetime.now().isoformat(),
            "step": step,
            "epoch": epoch,
            "is_warmup": is_warmup,
            **metrics
        }
        self.metric_history.append(metric_data)
        
        # 写入文件
        try:
            with open(self.metric_file, "a", encoding="utf-8") as f:
                f.write(json.dumps(metric_data, ensure_ascii=False) + "\n")
        except Exception as e:
            self.logger.error(f"指标写入失败：{str(e)}")
        
        # 更新最优指标
        if not is_warmup and "val_ppl" in metrics and metrics["val_ppl"] < self.best_val_ppl:
            self.best_val_ppl = metrics["val_ppl"]
            self.logger.info(f"【新最优模型】验证PPL降至：{self.best_val_ppl:.4f}")
        if not is_warmup and "val_loss" in metrics and metrics["val_loss"] < self.best_val_loss:
            self.best_val_loss = metrics["val_loss"]
        
        return True, metric_data

