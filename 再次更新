def _scan_corpus_files(self) -> List[str]:
"""递归扫描语料目录，过滤支持的格式，修复嵌套目录扫描bug"""
corpus_files = []
for root, _, files in os.walk(self.corpus_dir):
for file in files:
file_ext = os.path.splitext(file)[1].lower()
if file_ext in self.SUPPORTED_EXTENSIONS:
corpus_files.append(os.path.join(root, file))
self.logger.info(f"扫描到语料文件：{len(corpus_files)}个")
return corpus_files
 
def _load_txt_file(self, file_path: str) -> List[str]:
"""加载txt文件，按段落分割，修复空行处理bug"""
try:
with open(file_path, "r", encoding="utf-8", errors="ignore") as f:
content = f.read()
# 按双换行分割段落，保留文档结构
paragraphs = [p.strip() for p in re.split(r'\n\s*\n', content) if len(p.strip()) > 20]
return paragraphs
except Exception as e:
self.logger.error(f"TXT文件加载失败：{file_path}，错误：{str(e)}")
return []
 
def _load_jsonl_file(self, file_path: str) -> List[str]:
"""加载jsonl文件，修复空行、格式错误处理bug"""
paragraphs = []
try:
with open(file_path, "r", encoding="utf-8", errors="ignore") as f:
for line_num, line in enumerate(f):
line = line.strip()
if not line:
continue
try:
data = json.loads(line)
for key in self.text_key:
if key in data and isinstance(data[key], str):
text = data[key].strip()
if len(text) > 20:
paragraphs.append(text)
break
except json.JSONDecodeError:
self.logger.warning(f"JSONL文件{file_path}第{line_num+1}行格式错误，跳过")
continue
return paragraphs
except Exception as e:
self.logger.error(f"JSONL文件加载失败：{file_path}，错误：{str(e)}")
return []
 
def _load_parquet_file(self, file_path: str) -> List[str]:
"""加载parquet文件，修复大文件分块读取bug"""
paragraphs = []
try:
# 分块读取大文件，避免OOM
parquet_file = pq.ParquetFile(file_path)
for batch in parquet_file.iter_batches(batch_size=10000):
df = batch.to_pandas()
for col in df.columns:
if col.lower() in self.text_key:
texts = df[col].dropna().astype(str).tolist()
paragraphs.extend([t.strip() for t in texts if len(t.strip()) > 20])
break
return paragraphs
except Exception as e:
self.logger.error(f"Parquet文件加载失败：{file_path}，错误：{str(e)}")
return []
 
def _load_single_file(self, file_path: str) -> List[str]:
"""单文件分发加载，统一异常处理"""
file_ext = os.path.splitext(file_path)[1].lower()
if file_ext == ".txt":
return self._load_txt_file(file_path)
elif file_ext == ".jsonl":
return self._load_jsonl_file(file_path)
elif file_ext == ".parquet":
return self._load_parquet_file(file_path)
else:
self.logger.warning(f"不支持的文件格式：{file_ext}，跳过")
return []
 
def load_all_corpus(self) -> List[str]:
"""多进程并行加载全量语料，修复进程池泄漏bug"""
corpus_files = self._scan_corpus_files()
if len(corpus_files) == 0:
raise FileNotFoundError(f"语料目录{self.corpus_dir}中未找到任何支持的语料文件")
 
self.logger.info(f"开始并行加载语料，进程数：{self.num_workers}")
# 修复进程池不关闭导致的内存泄漏
with Pool(self.num_workers) as pool:
results = list(tqdm(
pool.imap(self._load_single_file, corpus_files),
total=len(corpus_files),
desc="语料加载"
))
pool.close()
pool.join()
 
# 合并结果
all_paragraphs = []
for res in results:
all_paragraphs.extend(res)
 
self.logger.info(f"语料加载完成，总段落数：{len(all_paragraphs)}")
return all_paragraphs
 
