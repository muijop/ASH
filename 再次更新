class TokenCacheManager:
"""Token缓存管理器，mmap内存映射，严格训练/验证/测试集划分，修复边界bug"""
def init(self, config: EasyDict, tokenizer: GPTTokenizerManager, logger: logging.Logger):
self.config = config
self.tokenizer = tokenizer
self.logger = logger
self.max_seq_len = config.max_seq_len
self.cache_dir = config.preprocessed_data_dir
self.train_cache_path = os.path.join(self.cache_dir, "train_tokens.npy")
self.val_cache_path = os.path.join(self.cache_dir, "val_tokens.npy")
self.test_cache_path = os.path.join(self.cache_dir, "test_tokens.npy")
self.meta_path = os.path.join(self.cache_dir, "meta.json")
 
def process_corpus_to_token_stream(self, cleaned_texts: List[str]) -> np.ndarray:
"""文档级Token流处理，保留文档边界，修复OOM bug"""
self.logger.info("开始构建Token流")
all_doc_tokens = []
 
for doc in tqdm(cleaned_texts, desc="文档分词"):
# 每个文档末尾加EOS，保留文档边界
doc_tokens = self.tokenizer.encode(doc, add_bos=False, add_eos=True)
if len(doc_tokens) >= 10:
all_doc_tokens.extend(doc_tokens)
 
self.logger.info(f"Token流构建完成，总token数：{len(all_doc_tokens)}")
self.tokenizer.get_oov_rate(cleaned_texts)
return np.array(all_doc_tokens, dtype=np.int64)
 
def build_token_cache(self, cleaned_texts: List[str]) -> Tuple[str, str, str]:
"""构建Token缓存，严格划分训练/验证/测试集，修复划分错误bug"""
if self.is_cache_valid():
self.logger.info("Token缓存已存在且有效，直接复用")
return self.train_cache_path, self.val_cache_path, self.test_cache_path
 
# 处理全量语料为token流
all_tokens = self.process_corpus_to_token_stream(cleaned_texts)
if len(all_tokens) < self.max_seq_len * 100:
raise ValueError(f"有效token数不足，无法完成训练：{len(all_tokens)}")
 
# 严格三集划分，修复比例错误bug
total_len = len(all_tokens)
train_split = int(total_len * self.config.train_ratio)
val_split = int(total_len * (self.config.train_ratio + self.config.val_ratio))
 
train_tokens = all_tokens[:train_split]
val_tokens = all_tokens[train_split:val_split]
test_tokens = all_tokens[val_split:]
 
# 保存缓存
np.save(self.train_cache_path, train_tokens)
np.save(self.val_cache_path, val_tokens)
np.save(self.test_cache_path, test_tokens)
 
# 保存元数据
meta = {
"total_tokens": len(all_tokens),
"train_tokens": len(train_tokens),
"val_tokens": len(val_tokens),
"test_tokens": len(test_tokens),
"max_seq_len": self.max_seq_len,
"vocab_size": self.tokenizer.vocab_size,
"create_time": datetime.now().isoformat()
}
with open(self.meta_path, "w", encoding="utf-8") as f:
json.dump(meta, f, ensure_ascii=False, indent=2)
 
self.logger.info(f"Token缓存构建完成：训练集{len(train_tokens)}token，验证集{len(val_tokens)}token，测试集{len(test_tokens)}token")
return self.train_cache_path, self.val_cache_path, self.test_cache_path
 
def is_cache_valid(self) -> bool:
"""检查缓存有效性，修复校验错误bug"""
if not all([
os.path.exists(self.train_cache_path),
os.path.exists(self.val_cache_path),
os.path.exists(self.test_cache_path),
os.path.exists(self.meta_path)
]):
return False
try:
with open(self.meta_path, "r", encoding="utf-8") as f:
meta = json.load(f)
if meta["max_seq_len"] != self.max_seq_len or meta["vocab_size"] != self.tokenizer.vocab_size:
return False
return True
except Exception as e:
self.logger.warning(f"缓存元数据校验失败：{str(e)}")
return False
 
def load_train_tokens(self) -> np.ndarray:
"""mmap加载训练集，极致降低内存占用"""
return np.load(self.train_cache_path, mmap_mode="r" if self.config.enable_mmap_token else None)
 
def load_val_tokens(self) -> np.ndarray:
"""mmap加载验证集"""
return np.load(self.val_cache_path, mmap_mode="r" if self.config.enable_mmap_token else None)
 
def load_test_tokens(self) -> np.ndarray:
"""mmap加载测试集"""
return np.load(self.test_cache_path, mmap_mode="r" if self.config.enable_mmap_token else None)
 
class StreamingPretrainDataset(IterableDataset):
"""流式预训练数据集，CPU内存友好，文档边界感知，修复边界溢出bug"""
def init(
self,
token_array: np.ndarray,
max_seq_len: int,
eos_id: int,
config: EasyDict,
is_validation: bool = False
):
super().init()
self.token_array = token_array
self.max_seq_len = max_seq_len
self.eos_id = eos_id
self.config = config
self.is_validation = is_validation
self.chunk_size = max_seq_len + 1  # 输入+目标各max_seq_len
# 预计算文档边界
self.doc_boundaries = np.where(self.token_array == eos_id)[0] + 1
 
def iter(self) -> Generator[Tuple[paddle.Tensor, paddle.Tensor], None, None]:
"""流式迭代生成样本，无内存占用，修复边界溢出bug"""
total_length = len(self.token_array)
# 验证集固定起点，训练集随机起点
current_idx = 0 if self.is_validation else random.randint(0, self.chunk_size // 2)
 
while current_idx + self.chunk_size < total_length:
# 文档边界感知切分，避免跨文档伪关联
if self.config.doc_boundary_aware:
boundary_in_chunk = self.doc_boundaries[
(self.doc_boundaries > current_idx) & (self.doc_boundaries < current_idx + self.chunk_size)
]
if len(boundary_in_chunk) > 0:
current_idx = boundary_in_chunk[-1]
if current_idx + self.chunk_size >= total_length:
break
 
# 提取序列，构建自回归输入输出
end_idx = current_idx + self.chunk_size
token_chunk = self.token_array[current_idx:end_idx]
input_ids = token_chunk[:-1]
target_ids = token_chunk[1:]
 
yield (
paddle.to_tensor(input_ids, dtype=paddle.int64),
paddle.to_tensor(target_ids, dtype=paddle.int64)
)
 
# 步长：序列长度-1，保证无重叠
current_idx += self.chunk_size - 1
 
def len(self) -> int:
"""估算样本总数"""
return len(self.token_array) // (self.chunk_size - 1)
 
====================================== 16. EMA、断点管理、评估函数（完整无截断） ======================================
 
class EMA:
"""EMA权重滑动平均，GPT系列训练必开，修复权重同步bug"""
def init(self, model: nn.Layer, decay: float = 0.9999):
self.model = model
self.decay = decay
self.shadow = {}
self.backup = {}
# 初始化影子权重
for name, param in model.named_parameters():
if not param.stop_gradient:
self.shadow[name] = param.clone().detach()
 
def update(self):
"""每步更新影子权重，修复数值错误bug"""
for name, param in self.model.named_parameters():
if not param.stop_gradient:
self.shadow[name] = self.decay * self.shadow[name] + (1 - self.decay) * param.detach()
 
def apply_shadow(self):
"""验证时应用影子权重"""
for name, param in self.model.named_parameters():
if not param.stop_gradient:
self.backup[name] = param.clone()
param.set_value(self.shadow[name])
 
def restore(self):
"""验证后恢复原权重"""
for name, param in self.model.named_parameters():
if not param.stop_gradient:
param.set_value(self.backup[name])
self.backup = {}
 
def save_checkpoint(
config: EasyDict, model: nn.Layer, optimizer: paddle.optimizer.Optimizer,
scheduler: LRScheduler, ema: Optional[EMA], tokenizer: GPTTokenizerManager,
global_step: int, epoch: int, val_ppl: float, is_best: bool = False,
is_warmup_checkpoint: bool = False
):
"""全状态断点保存，支持断点续训，修复文件损坏bug"""
checkpoint = {
"config": dict(config),
"model_state_dict": model.state_dict(),
"optimizer_state_dict": optimizer.state_dict(),
"scheduler_state_dict": scheduler.state_dict(),
"ema_shadow": ema.shadow if ema is not None else None,
"tokenizer_vocab_size": tokenizer.vocab_size,
"global_step": global_step,
"epoch": epoch,
"val_ppl": val_ppl,
"is_warmup_checkpoint": is_warmup_checkpoint,
"timestamp": datetime.now().isoformat()
}
 
# 先写入临时文件，避免保存中断导致文件损坏
temp_path = os.path.join(config.checkpoint_dir, "temp_checkpoint.pdparams")
latest_path = os.path.join(config.checkpoint_dir, "latest_checkpoint.pdparams")
paddle.save(checkpoint, temp_path)
 
# 原子替换
if os.path.exists(latest_path):
os.replace(temp_path, latest_path)
else:
os.rename(temp_path, latest_path)
 
LOGGER.info(f"断点保存完成，步数：{global_step}，路径：{latest_path}")
 
# 保存最优断点
if is_best:
best_path = os.path.join(config.checkpoint_dir, "best_checkpoint.pdparams")
shutil.copyfile(latest_path, best_path)
LOGGER.info(f"最优断点更新，验证PPL：{val_ppl:.4f}，路径：{best_path}")
 
# 保存预热阶段断点
if is_warmup_checkpoint:
warmup_path = os.path.join(config.checkpoint_dir, "warmup_checkpoint.pdparams")
shutil.copyfile(latest_path, warmup_path)
LOGGER.info(f"预热阶段断点保存完成，路径：{warmup_path}")
 
def load_checkpoint(
config: EasyDict, model: nn.Layer, optimizer: paddle.optimizer.Optimizer,
scheduler: LRScheduler, ema: Optional[EMA]
) -> Tuple[int, int, float, bool]:
"""断点加载，恢复训练状态，修复预热状态丢失bug"""
latest_path = os.path.join(config.checkpoint_dir, "latest_checkpoint.pdparams")
if not os.path.exists(latest_path) or not config.enable_auto_resume:
LOGGER.info("未找到断点，从头开始训练")
return 0, 0, float("inf"), False
 
LOGGER.info(f"加载断点：{latest_path}")
checkpoint = paddle.load(latest_path)
 
# 加载状态
model.set_state_dict(checkpoint["model_state_dict"])
optimizer.set_state_dict(checkpoint["optimizer_state_dict"])
scheduler.set_state_dict(checkpoint["scheduler_state_dict"])
if ema is not None and checkpoint["ema_shadow"] is not None:
ema.shadow = checkpoint["ema_shadow"]
 
# 恢复训练进度
global_step = checkpoint["global_step"]
start_epoch = checkpoint["epoch"]
best_val_ppl = checkpoint["val_ppl"]
is_warmup_completed = checkpoint.get("is_warmup_checkpoint", False)
 
LOGGER.info(f"断点加载完成，起始步数：{global_step}，起始轮次：{start_epoch}，最优PPL：{best_val_ppl:.4f}")
return global_step, start_epoch, best_val_ppl, is_warmup_completed
 
def evaluate(
model: nn.Layer, data_loader: DataLoader, vocab_size: int,
ema: Optional[EMA] = None, max_batches: int = None
) -> Tuple[float, float]:
"""模型评估，返回平均损失和困惑度PPL，修复数值错误bug"""
# 应用EMA权重
if ema is not None:
ema.apply_shadow()
 
model.eval()
total_loss = 0.0
total_samples = 0
 
with paddle.no_grad():
for batch_idx, (x, y) in enumerate(data_loader):
if max_batches is not None and batch_idx >= max_batches:
break
logits, z_loss = model(x)
ce_loss = F.cross_entropy(
logits.reshape([-1, vocab_size]),
y.reshape([-1])
)
batch_loss = (ce_loss + z_loss).numpy()[0]
total_loss += batch_loss * len(x)
total_samples += len(x)
 
# 恢复原模型权重
if ema is not None:
ema.restore()
 
avg_loss = total_loss / total_samples
val_ppl = np.exp(avg_loss)
model.train()
return avg_loss, val_ppl
 
====================================== 17. 多阶段预热核心函数（新增） ======================================
 
def embedding_warmup_stage(
model: GPTBackbone,
train_loader: DataLoader,
val_loader: DataLoader,
config: EasyDict,
tokenizer: GPTTokenizerManager,
logger: logging.Logger
) -> GPTBackbone:
"""阶段1：嵌入层预热，冻结主干网络，只训练词嵌入，解决初始化不稳定bug"""
if not config.enable_embedding_warmup:
logger.info("跳过嵌入层预热")
return model
 
# 计算预热步数
total_train_samples = len(train_loader.dataset)
warmup_steps = int(total_train_samples * config.embedding_warmup_steps_ratio)
warmup_steps = max(100, warmup_steps)
logger.info(f"开始嵌入层预热，总步数：{warmup_steps}")
 
# 冻结主干网络，只开放嵌入层和LM头
for name, param in model.named_parameters():
if "token_embedding" not in name and "lm_head" not in name:
param.stop_gradient = True
else:
param.stop_gradient = False
 
# 预热阶段优化器
warmup_optimizer = paddle.optimizer.AdamW(
parameters=[p for p in model.parameters() if not p.stop_gradient],
learning_rate=config.embedding_warmup_lr,
beta1=0.9,
beta2=0.95,
epsilon=1e-8,
weight_decay=0.0
)
 
# 预热阶段训练
model.train()
progress_bar = tqdm(range(warmup_steps), desc="嵌入层预热")
train_iter = iter(train_loader)
 
for step in progress_bar:
try:
x, y = next(train_iter)
except StopIteration:
train_iter = iter(train_loader)
x, y = next(train_iter)
 
# 前向传播
logits, z_loss = model(x)
ce_loss = F.cross_entropy(
logits.reshape([-1, tokenizer.vocab_size]),
y.reshape([-1])
)
total_loss = ce_loss + z_loss
 
# 反向传播
total_loss.backward()
warmup_optimizer.step()
warmup_optimizer.clear_grad()
 
# 日志更新
if step % config.log_interval == 0:
train_ppl = np.exp(ce_loss.numpy()[0])
metrics = {
"warmup_step": step,
"ce_loss": ce_loss.numpy()[0].item(),
"z_loss": z_loss.numpy()[0].item(),
"total_loss": total_loss.numpy()[0].item(),
"train_ppl": train_ppl.item()
}
WARMUP_METRIC_MANAGER.log_metrics(step, 0, metrics, is_warmup=True)
progress_bar.set_postfix({
"loss": f"{total_loss.numpy()[0]:.4f}",
"ppl": f"{train_ppl:.2f}"
})
 
# 解冻所有参数
for param in model.parameters():
param.stop_gradient = False
 
# 保存预热断点
save_checkpoint(
config, model, warmup_optimizer, None, None, tokenizer,
warmup_steps, 0, float("inf"), is_best=False, is_warmup_checkpoint=True
)
 
logger.info("嵌入层预热完成，所有参数已解冻")
return model
 
