# ====================================== 【单语料训练主流程】 ======================================
def train_single_corpus(
    model, optimizer, scheduler, tokenizer,
    corpus_path, corpus_num, global_step, total_corpus,
    amp_scaler=None, quantizer=None
):
    corpus_name = os.path.basename(corpus_path)
    write_log(f"\n{'='*60}")
    write_log(f"训练第{corpus_num}号语料：{corpus_name} | 进度：{corpus_num}/{total_corpus}")
    write_log(f"{'='*60}")

    # 加载语料
    train_data, val_data = load_single_corpus(corpus_path, tokenizer)
    train_dataset = paddle.io.TensorDataset(train_data)
    steps_per_epoch = len(train_dataset) // BATCH_SIZE_PER_STEP
    total_steps = steps_per_epoch * MAX_EPOCHS_PER_CORPUS
    write_log(f"📊 总训练步数：{total_steps}，每轮步数：{steps_per_epoch}")

    # 自适应预热
    warmup_steps = max(50, min(int(total_steps * 0.02), 500))
    warmup_stable_steps = max(20, int(warmup_steps * 0.5))
    base_scheduler = CosineAnnealingWarmRestarts(learning_rate=BASE_LR, T_0=max(500, int(total_steps * 0.1)), T_mult=2)
    warmup_scheduler = LinearWarmup(base_scheduler, warmup_steps=warmup_steps, start_lr=1e-6, end_lr=BASE_LR)
    corpus_scheduler = SequentialLR(
        schedulers=[warmup_scheduler, ConstantLR(BASE_LR, total_steps=warmup_stable_steps), base_scheduler],
        milestones=[warmup_steps, warmup_steps + warmup_stable_steps]
    )
    optimizer.set_lr_scheduler(corpus_scheduler)

    # 数据加载器
    train_loader = paddle.io.DataLoader(
        train_dataset,
        batch_size=BATCH_SIZE_PER_STEP,
        shuffle=True,
        num_workers=min(2, PHYSICAL_CPU_CORES),
        prefetch_factor=4,
        drop_last=True
    )

    # 训练初始化
    best_ppl = float("inf")
    patience_counter = 0
    model.train()

    # 训练循环
    for epoch in range(MAX_EPOCHS_PER_CORPUS):
        epoch_loss = 0.0
        pbar = tqdm(train_loader, desc=f"Epoch {epoch+1}/{MAX_EPOCHS_PER_CORPUS}")
        for step, (x, y) in enumerate(pbar):
            optimizer.clear_grad()
            accum_steps = GRADIENT_ACCUMULATION_STEPS
            warmup_ratio = min(1.0, global_step / (warmup_steps + warmup_stable_steps))

            # 混合精度前向传播
            with paddle.amp.auto_cast(enable=USE_AUTO_MIXED_PRECISION, dtype="float16", level="O1"):
                logits = model(x, warmup_ratio=warmup_ratio)
                loss = F.cross_entropy(logits.reshape([-1, VOCAB_SIZE]), y.reshape([-1]), label_smoothing=0.03)
                loss = loss / accum_steps

            # 混合精度反向传播
            if USE_AUTO_MIXED_PRECISION:
                amp_scaler.scale(loss).backward()
            else:
                loss.backward()

            # 梯度累积更新
            if (step + 1) % accum_steps == 0:
                if USE_AUTO_MIXED_PRECISION:
                    amp_scaler.unscale_(optimizer)
                nn.utils.clip_grad_norm_(model.parameters(), MAX_GRAD_NORM)
                if USE_AUTO_MIXED_PRECISION:
                    amp_scaler.step(optimizer)
                    amp_scaler.update()
                else:
                    optimizer.step()
                corpus_scheduler.step()
                optimizer.clear_grad()

            # 步数更新
            global_step += 1
            epoch_loss += loss.item() * accum_steps
            avg_loss = epoch_loss / (step + 1)
            pbar.set_postfix({
                "loss": round(avg_loss, 4),
                "lr": round(corpus_scheduler.get_lr(), 7),
                "warmup": f"{int(warmup_ratio*100)}%"
            })

        # 每轮验证
        val_loss, val_ppl = evaluate(model, val_data, amp_scaler)
        train_avg_loss = epoch_loss / len(train_loader)
        write_log(f"\n📈 Epoch {epoch+1} 结束 | 训练Loss: {train_avg_loss:.6f} | 验证Loss: {val_loss:.6f} | 验证PPL: {val_ppl:.2f}")

        # 早停判断
        if val_ppl < best_ppl:
            best_ppl = val_ppl
            patience_counter = 0
            # 保存最优模型
            best_model_path = os.path.join(MODEL_SAVE_DIR, f"corpus_{corpus_num}_best_model.pdparams")
            paddle.save(model.state_dict(), best_model_path)
            write_log(f"✨ 最优模型已保存，PPL: {best_ppl:.2f}")
        else:
            patience_counter += 1
            write_log(f"⏳ 耐心值：{patience_counter}/{EARLY_STOP_PATIENCE}")

        # 触发早停
        if epoch >= MIN_EPOCHS_PER_CORPUS and patience_counter >= EARLY_STOP_PATIENCE:
            write_log(f"🛑 触发早停，结束训练")
            break

        # 保存断点
        save_global_checkpoint(model, optimizer, scheduler, corpus_num-1, epoch+1, global_step, quantizer)

    # 语料训练完成，保存最终模型
    final_model_path = os.path.join(MODEL_SAVE_DIR, f"corpus_{corpus_num}_final_model.pdparams")
    paddle.save(model.state_dict(), final_model_path)
    write_log(f"\n🎉 第{corpus_num}号语料训练完成！")
    write_log(f"📁 最终模型：{final_model_path}")
    write_log(f"📊 最优PPL: {best_ppl:.2f}")

    # 混合量化：语料训练完成后，导出INT8量化模型
    if USE_MIXED_PRECISION_QUANT and quantizer:
        write_log("\n🔄 开始导出INT8混合量化模型...")
        quant_model = quantizer.quantize(model)
        quant_model_path = os.path.join(QUANT_MODEL_DIR, f"corpus_{corpus_num}_int8_quant_model.pdparams")
        paddle.save(quant_model.state_dict(), quant_model_path)
        write_log(f"✅ INT8量化模型已保存：{quant_model_path}")

    return model, optimizer, scheduler, global_step

