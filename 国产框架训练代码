            model.set_state_dict(paddle.load(os.path.join(MODEL_SAVE_DIR, f"corpus_{corpus_num}_final_model.pdparams")))
            continue

        # 训练当前语料
        model, optimizer, scheduler, global_step = train_single_corpus(
            model=model,
            optimizer=optimizer,
            scheduler=scheduler,
            tokenizer=tokenizer,
            corpus_path=corpus_path,
            corpus_num=corpus_num,
            global_step=global_step,
            total_corpus=total_corpus,
            amp_scaler=amp_scaler,
            quantizer=quantizer
        )

    # 9. 训练全部完成，保存最终模型
    paddle.save(model.state_dict(), FINAL_MODEL_PATH)
    # 导出最终INT8量化模型
    if USE_MIXED_PRECISION_QUANT and quantizer:
        final_quant_model = quantizer.convert(model)
        paddle.jit.save(final_quant_model, os.path.join(QUANT_MODEL_DIR, "final_int8_infer_model"))
