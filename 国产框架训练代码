    # 最终总结
    write_log(f"\n{'='*60}")
    write_log("🎉 所有语料训练全部完成！")
    write_log(f"{'='*60}")
    write_log(f"📊 总训练语料数：{total_corpus}")
    write_log(f"📊 全局总训练步数：{global_step}")
    write_log(f"📁 单语料模型保存文件夹：{MODEL_SAVE_DIR}")
    write_log(f"📁 INT8量化模型保存文件夹：{QUANT_MODEL_DIR}")
    write_log(f"📁 全量最终模型：{FINAL_MODEL_PATH}")
