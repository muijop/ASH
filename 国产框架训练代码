if __name__ == "__main__":
    write_log("="*60)
    write_log("INT8混合量化 + 混合精度AMP + 混合参数MoE 训练程序启动")
    write_log("="*60)

    # 1. 扫描语料
    corpus_nums, corpus_paths = scan_and_sort_corpus()
    total_corpus = len(corpus_nums)

    # 2. 加载分词器
    tokenizer = get_global_tokenizer(corpus_paths)

    # 3. 初始化模型
    model = TextLLModel()
    model = paddle.jit.to_static(model, build_strategy=paddle.static.BuildStrategy())
    total_params = sum(p.numel() for p in model.parameters())
    write_log(f"\n✅ 模型初始化完成，总参数量：{total_params/1e6:.2f}M")

    # 4. 初始化混合精度梯度缩放器
    amp_scaler = paddle.amp.GradScaler(enable=USE_AUTO_MIXED_PRECISION, init_loss_scaling=2**16)
    write_log(f"✅ 自动混合精度AMP：{'已开启' if USE_AUTO_MIXED_PRECISION else '已关闭'}")

    # 5. 初始化混合量化器
    quantizer = None
    if USE_MIXED_PRECISION_QUANT:
        quant_config = get_mixed_quant_config()
        quantizer = QAT(config=quant_config)
        model = quantizer.quantize(model)
        write_log(f"✅ 混合精度量化：已开启，层级INT8+FP32混合")

    # 6. 初始化优化器
    trainable_params = [p for p in model.parameters() if not p.stop_gradient]
    optimizer = Lion(trainable_params, lr=BASE_LR, weight_decay=WEIGHT_DECAY)
    global_scheduler = CosineAnnealingWarmRestarts(learning_rate=BASE_LR, T_0=1000, T_mult=2)
    optimizer.set_lr_scheduler(global_scheduler)

    # 7. 加载断点
    model, optimizer, scheduler, start_corpus_idx, start_epoch, global_step = load_global_checkpoint(model, optimizer, global_scheduler, quantizer)

    # 8. 顺序训练所有语料
    write_log(f"\n🚀 开始顺序训练，总语料数：{total_corpus}")
    for idx in range(start_corpus_idx, total_corpus):
        corpus_num = corpus_nums[idx]
        corpus_path = corpus_paths[idx]

        # 跳过已训练的语料
        if check_corpus_trained(corpus_num):
