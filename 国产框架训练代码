# ====================================== 【混合量化配置：层级精度混合】 ======================================
def get_mixed_quant_config():
    """
    混合量化核心配置：
    - 计算密集层（Linear/Conv）：INT8量化，PerChannel最小最大观察器
    - 精度敏感层（Embedding、Softmax、LayerNorm）：跳过量化，保持FP32/FP16
    """
    quant_config = QuantConfig(
        activation_observer=MovingAverageMinMaxObserver(
            quant_bits=8,
            symmetric=True,
            moving_avg_rate=0.9
        ),
        weight_observer=PerChannelMinMaxObserver(
            quant_bits=8,
            symmetric=True,
            channel_axis=0
        ),
        # 跳过精度敏感层，不做量化
        skip_quant_layer_types=[nn.Embedding, nn.Softmax, nn.LayerNorm, DeepNorm]
    )
    return quant_config

# ====================================== 【核心模型模块：混合精度+MoE+量化友好】 ======================================
class DeepNorm(nn.Layer):
    def __init__(self, dim: int, eps: float = 1e-6, alpha: float = 0.81):
        super().__init__()
        self.eps = eps
        self.alpha = alpha
        self.weight = self.create_parameter(shape=[dim], default_initializer=nn.initializer.Constant(1.0))

    def forward(self, x: paddle.Tensor):
        return x * self.alpha * paddle.rsqrt(x.pow(2).mean(-1, keepdim=True) + self.eps) * self.weight

class RoPE(nn.Layer):
    def __init__(self, head_dim: int, max_seq_len: int):
        super().__init__()
        theta = 1.0 / (10000 ** (paddle.arange(0, head_dim, 2).astype(paddle.float32) / head_dim))
        seq_idx = paddle.arange(max_seq_len).astype(paddle.float32)
        freqs = paddle.outer(seq_idx, theta)
        self.register_buffer("cos", freqs.cos()[None, None, :, :])
        self.register_buffer("sin", freqs.sin()[None, None, :, :])

    def forward(self, x: paddle.Tensor):
        seq_len = x.shape[2]
        cos = self.cos[:, :, :seq_len, :].astype(x.dtype)
        sin = self.sin[:, :, :seq_len, :].astype(x.dtype)
        x1, x2 = x.chunk(2, axis=-1)
        return paddle.concat([x1 * cos - x2 * sin, x1 * sin + x2 * cos], axis=-1)

class GQAAttention(nn.Layer):
    def __init__(self):
        super().__init__()
        self.head_dim = EMBED_DIM // NUM_Q_HEADS
        self.num_q_heads = NUM_Q_HEADS
        self.num_kv_heads = NUM_KV_HEADS
        self.kv_repeat = self.num_q_heads // self.num_kv_heads

        # QKV合并投影，量化友好，减少内存访问
        self.qkv_proj = nn.Linear(EMBED_DIM, (self.num_q_heads + 2*self.num_kv_heads) * self.head_dim, bias_attr=False)
        self.out_proj = nn.Linear(EMBED_DIM, EMBED_DIM, bias_attr=False)

        self.rope = RoPE(self.head_dim, MAX_SEQ_LEN)
        self.register_buffer("causal_mask", paddle.tril(paddle.ones((1, 1, MAX_SEQ_LEN, MAX_SEQ_LEN))))
        self.sparse_topk = min(32, MAX_SEQ_LEN)

    def forward(self, x: paddle.Tensor):
        batch_size, seq_len, _ = x.shape
        qkv = self.qkv_proj(x)
        q = qkv[:, :, :self.num_q_heads*self.head_dim].reshape([batch_size, seq_len, self.num_q_heads, self.head_dim]).transpose([0, 2, 1, 3])
        k = qkv[:, :, self.num_q_heads*self.head_dim:(self.num_q_heads+self.num_kv_heads)*self.head_dim].reshape([batch_size, seq_len, self.num_kv_heads, self.head_dim]).transpose([0, 2, 1, 3])
        v = qkv[:, :, (self.num_q_heads+self.num_kv_heads)*self.head_dim:].reshape([batch_size, seq_len, self.num_kv_heads, self.head_dim]).transpose([0, 2, 1, 3])

        q = self.rope(q)
        k = self.rope(k)
        k = k.repeat_interleave(self.kv_repeat, axis=1)
        v = v.repeat_interleave(self.kv_repeat, axis=1)

        attn_scores = (q @ k.transpose([0, 1, 3, 2])) / (self.head_dim ** 0.5)
        attn_scores = attn_scores.masked_fill(self.causal_mask[:, :, :seq_len, :seq_len] == 0, float("-inf"))
        
        # CPU稀疏优化，减少计算量
        top_k = min(self.sparse_topk, seq_len)
        top_k_values, _ = paddle.topk(attn_scores, top_k, axis=-1)
        attn_scores = attn_scores.masked_fill(attn_scores < top_k_values[..., -1, None], float("-inf"))

        attn_weights = F.softmax(attn_scores, axis=-1)
        attn_weights = attn_weights.masked_fill(attn_scores == float("-inf"), 0.0)
        attn_output = (attn_weights @ v).transpose([0, 2, 1, 3]).reshape([batch_size, seq_len, EMBED_DIM])
        return self.out_proj(attn_output)

class SwiGLU(nn.Layer):
    def __init__(self):
        super().__init__()
        hidden_dim = int(EMBED_DIM * FFN_EXPANSION_RATIO)
        self.w13_proj = nn.Linear(EMBED_DIM, 2*hidden_dim, bias_attr=False)
        self.w2 = nn.Linear(hidden_dim, EMBED_DIM, bias_attr=False)

    def forward(self, x: paddle.Tensor):
        w1_out, w3_out = self.w13_proj(x).chunk(2, axis=-1)
        return self.w2(F.silu(w1_out) * w3_out)

class MoEExpertLayer(nn.Layer):
    """混合参数MoE混合专家层：稀疏激活，CPU友好"""
    def __init__(self, dim: int, num_experts: int = MOE_EXPERT_NUM, top_k: int = MOE_TOP_K):
        super().__init__()
        self.dim = dim
        self.num_experts = num_experts
        self.top_k = top_k
        self.gate = nn.Linear(dim, num_experts, bias_attr=False)
        self.experts = nn.LayerList([SwiGLU() for _ in range(num_experts)])

    def forward(self, x: paddle.Tensor):
        batch_size, seq_len, dim = x.shape
        gate_logits = self.gate(x)
        gate_weights = F.softmax(gate_logits, axis=-1)
        top_k_weights, top_k_indices = paddle.topk(gate_weights, self.top_k, axis=-1)
        top_k_weights = top_k_weights / top_k_weights.sum(axis=-1, keepdim=True)

        expert_outputs = paddle.zeros_like(x)
        for expert_idx in range(self.num_experts):
            mask = (top_k_indices == expert_idx).any(axis=-1)
            if mask.sum() == 0:
                continue
            expert_input = x[mask]
            expert_out = self.experts[expert_idx](expert_input)
            weight = top_k_weights[mask][:, top_k_indices[mask] == expert_idx].mean(axis=-1, keepdim=True)
            expert_outputs[mask] += expert_out * weight
        return expert_outputs

class DecoderLayer(nn.Layer):
    def __init__(self, layer_idx: int):
        super().__init__()
        self.attn_norm = DeepNorm(EMBED_DIM)
        self.attn = GQAAttention()
        self.ffn_norm = DeepNorm(EMBED_DIM)
        # 混合参数：偶数层用MoE，奇数层用普通SwiGLU，平衡速度和容量
        self.ffn = MoEExpertLayer(EMBED_DIM) if (USE_MOE_MIXED_PARAMS and layer_idx % 2 == 0) else SwiGLU()
        self.res_scale = self.create_parameter(shape=[1], default_initializer=nn.initializer.Constant(0.1))

    def forward(self, x: paddle.Tensor, global_res: paddle.Tensor, warmup_ratio: float = 1.0):
        scale = self.res_scale * warmup_ratio
        attn_out = x + self.attn(self.attn_norm(x)) * scale
        ffn_out = attn_out + self.ffn(self.ffn_norm(attn_out)) * scale
        ffn_out = ffn_out + global_res * 0.05 * warmup_ratio
        return ffn_out

class TextLLModel(nn.Layer):
    def __init__(self):
        super().__init__()
        self.token_embedding = nn.Embedding(VOCAB_SIZE, EMBED_DIM)
        self.decoder_layers = nn.LayerList([DecoderLayer(layer_idx=i) for i in range(NUM_LAYERS)])
        self.final_norm = DeepNorm(EMBED_DIM)
        self.lm_head = nn.Linear(EMBED_DIM, VOCAB_SIZE, bias_attr=False)
        self.token_embedding.weight = self.lm_head.weight  # 权重共享，减少参数量

    def forward(self, input_ids: paddle.Tensor, warmup_ratio: float = 1.0):
        x = self.token_embedding(input_ids)
        global_res = x
        for layer in self.decoder_layers:
            x = layer(x, global_res, warmup_ratio)
        x = self.final_norm(x)
        logits = self.lm_head(x)
        return logits

# ====================================== 【优化器：混合精度适配版Lion】 ======================================
class Lion(paddle.optimizer.Optimizer):
    def __init__(self, params, lr=1e-4, betas=(0.9, 0.99), weight_decay=0.01):
        if lr < 0.0:
            raise ValueError(f"学习率不能为负数，当前lr: {lr}")
        defaults = dict(lr=lr, betas=betas, weight_decay=weight_decay)
        super().__init__(learning_rate=lr, parameters=params, weight_decay=0.0, defaults=defaults)

    @paddle.no_grad()
    def _step(self):
        for group in self._param_groups:
            for p in group['params']:
                if p.grad is None:
                    continue
                grad = p.grad
                state = self._state_dict[p.name]
                if len(state) == 0:
                    state['exp_avg'] = paddle.zeros_like(p, dtype=paddle.float16 if USE_AUTO_MIXED_PRECISION else paddle.float32)
                exp_avg = state['exp_avg'].cast(paddle.float32)
                beta1, beta2 = group['betas']
                lr = group['lr']
                weight_decay = group['weight_decay']

                update = paddle.sign(beta1 * exp_avg + (1 - beta1) * grad)
                if weight_decay != 0:
                    p = p * (1 - lr * weight_decay)
                p = p - lr * update
                exp_avg = beta2 * exp_avg + (1 - beta2) * grad
                state['exp_avg'] = exp_avg.cast(paddle.float16) if USE_AUTO_MIXED_PRECISION else exp_avg
        return

# ====================================== 【语料处理：自动扫描+顺序加载】 ======================================
def scan_and_sort_corpus():
    """自动扫描数字命名的txt语料，严格按数字升序排序"""
    write_log("\n🔄 扫描当前文件夹内的语料文件...")
    all_txt_files = glob.glob(os.path.join(CURRENT_DIR, "*.txt"))
    corpus_pattern = re.compile(r"^(\d+)\.txt$")
    corpus_list = []
    for file_path in all_txt_files:
        file_name = os.path.basename(file_path)
        match = corpus_pattern.match(file_name)
        if match:
            corpus_num = int(match.group(1))
            corpus_list.append((corpus_num, file_path))
    corpus_list.sort(key=lambda x: x[0])
    sorted_nums = [x[0] for x in corpus_list]
    sorted_paths = [x[1] for x in corpus_list]
    if len(sorted_paths) == 0:
        raise FileNotFoundError("未找到1.txt、2.txt、3.txt等数字命名的语料文件")
    write_log(f"✅ 扫描完成，共{len(sorted_paths)}个语料，按顺序排列：")
    for num, path in zip(sorted_nums, sorted_paths):
        write_log(f"  [{num}] {os.path.basename(path)}")
    return sorted_nums, sorted_paths

def get_global_tokenizer(corpus_paths):
    """全局统一分词器，用所有语料训练"""
    if os.path.exists(TOKENIZER_MODEL_PATH):
        sp = spm.SentencePieceProcessor(model_file=TOKENIZER_MODEL_PATH)
        write_log("✅ 加载全局分词器成功")
        return sp
    else:
        write_log("🔄 训练全局统一分词器...")
        all_text = ""
        for path in tqdm(corpus_paths, desc="加载语料"):
            with open(path, "r", encoding="utf-8", errors="ignore") as f:
                all_text += f.read() + "\n"
        temp_file = os.path.join(TOKENIZER_DIR, "temp_corpus.txt")
        with open(temp_file, "w", encoding="utf-8") as f:
            f.write(all_text)
        spm.SentencePieceTrainer.train(
            input=temp_file,
            model_prefix=os.path.join(TOKENIZER_DIR, "text_spm"),
            vocab_size=VOCAB_SIZE,
            character_coverage=0.9995,
            model_type="bpe"
        )
        os.remove(temp_file)
        sp = spm.SentencePieceProcessor(model_file=TOKENIZER_MODEL_PATH)
        write_log("✅ 分词器训练完成")
        return sp

def load_single_corpus(corpus_path, tokenizer):
    """加载单个语料，划分训练/验证集"""
    corpus_name = os.path.basename(corpus_path)
    write_log(f"\n📄 加载语料：{corpus_name}")
    with open(corpus_path, "r", encoding="utf-8", errors="ignore") as f:
        lines = f.readlines()
    valid_paras = []
    para_set = set()
    current_para = ""
    for line in lines:
        line = line.strip()
        if len(line) == 0:
            if len(current_para) > 30 and current_para not in para_set:
                para_set.add(current_para)
                valid_paras.append(current_para)
            current_para = ""
        else:
            current_para += line + " "
    if len(current_para) > 30 and current_para not in para_set:
        valid_paras.append(current_para)
    if len(valid_paras) == 0:
        raise ValueError(f"{corpus_name} 无有效内容")
    random.shuffle(valid_paras)
    split_idx = int(len(valid_paras) * (1 - VAL_RATIO))
    train_paras = valid_paras[:split_idx]
    val_paras = valid_paras[split_idx:]
    write_log(f"📊 语料划分：训练集{len(train_paras)}段，验证集{len(val_paras)}段")

    def paras_to_tensor(paras):
        all_ids = []
        for para in paras:
            all_ids.extend(tokenizer.encode(para, out_type=int))
        chunks = []
        for i in range(0, len(all_ids) - MAX_SEQ_LEN, MAX_SEQ_LEN):
            chunk = all_ids[i:i+MAX_SEQ_LEN]
            if len(chunk) == MAX_SEQ_LEN:
                chunks.append(chunk)
        if not chunks:
            return None
        tensor = paddle.to_tensor(chunks, dtype=paddle.int64)
        return tensor[:, :-1], tensor[:, 1:]
    
    train_data = paras_to_tensor(train_paras)
    val_data = paras_to_tensor(val_paras)
    if train_data is None or val_data is None:
        raise ValueError(f"{corpus_name} 转换失败")
    return train_data, val_data

def evaluate(model, val_data, amp_scaler=None):
    """验证集评估"""
    model.eval()
    total_loss = 0.0
    x_val, y_val = val_data
    val_loader = paddle.io.DataLoader(
        paddle.io.TensorDataset([x_val, y_val]),
        batch_size=BATCH_SIZE_PER_STEP,
        shuffle=False,
        num_workers=min(2, PHYSICAL_CPU_CORES)
    )
    with paddle.no_grad():
        for x, y in val_loader:
            with paddle.amp.auto_cast(enable=USE_AUTO_MIXED_PRECISION, dtype="float16", level="O1"):
                logits = model(x)
                loss = F.cross_entropy(logits.reshape([-1, VOCAB_SIZE]), y.reshape([-1]))
            total_loss += loss.item()
    avg_loss = total_loss / len(val_loader)
    ppl = paddle.exp(paddle.to_tensor(avg_loss)).item()
    model.train()
    return avg_loss, ppl

# ====================================== 【断点续训工具】 ======================================
def save_global_checkpoint(model, optimizer, scheduler, corpus_idx, epoch, global_step, quantizer=None):
    ckpt = {
        "model_state": model.state_dict(),
        "optimizer_state": optimizer.state_dict(),
        "scheduler_state": scheduler.state_dict(),
        "corpus_idx": corpus_idx,
        "epoch": epoch,
        "global_step": global_step,
        "quantizer_state": quantizer.state_dict() if quantizer else None
    }
    paddle.save(ckpt, GLOBAL_CKPT_PATH)

def load_global_checkpoint(model, optimizer, scheduler, quantizer=None):
    start_corpus_idx = 0
    start_epoch = 0
    global_step = 0
    if os.path.exists(GLOBAL_CKPT_PATH):
        write_log("\n🔄 加载全局断点...")
        ckpt = paddle.load(GLOBAL_CKPT_PATH)
        model.set_state_dict(ckpt["model_state"])
        optimizer.set_state_dict(ckpt["optimizer_state"])
        scheduler.set_state_dict(ckpt["scheduler_state"])
        start_corpus_idx = ckpt["corpus_idx"]
        start_epoch = ckpt["epoch"]
        global_step = ckpt["global_step"]
        if quantizer and ckpt["quantizer_state"]:
            quantizer.set_state_dict(ckpt["quantizer_state"])
        write_log(f"✅ 断点加载完成，从第{start_corpus_idx+1}个语料继续")
    return model, optimizer, scheduler, start_corpus_idx, start_epoch, global_step

