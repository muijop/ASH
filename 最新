def set_random_seed(seed: int = 42, deterministic: bool = True):
    """固定全链路随机种子，保证训练可复现，兼容你原代码的确定性要求"""
    random.seed(seed)
    np.random.seed(seed)
    paddle.seed(seed)
    os.environ["PYTHONHASHSEED"] = str(seed)
    if deterministic:
        os.environ["FLAGS_cpu_deterministic"] = "1"
        paddle.set_flags({"FLAGS_cpu_deterministic": True})

def setup_cpu_env(config: EasyDict):
    """Intel/国产CPU极致优化，解决你原代码CPU训练速度慢的问题"""
    cpu_cores = config.physical_cpu_cores
    
    # 核心线程与MKL优化
    os.environ["OMP_NUM_THREADS"] = str(cpu_cores)
    os.environ["MKL_NUM_THREADS"] = str(cpu_cores)
    os.environ["MKL_ENABLE_INSTRUCTIONS"] = config.avx_instruction_set
    os.environ["KMP_AFFINITY"] = "granularity=fine,compact,1,0"
    os.environ["KMP_BLOCKTIME"] = "1"
    
    # Paddle MKL-DNN加速
    if config.enable_mkldnn:
        os.environ["FLAGS_use_mkldnn"] = "1"
        paddle.set_flags({"FLAGS_use_mkldnn": True})
    
    # 内存优化
    os.environ["FLAGS_eager_delete_tensor_gb"] = "0.0"
    os.environ["FLAGS_allocator_strategy"] = "auto_growth"
    os.environ["FLAGS_fast_eager_deletion_mode"] = "1"
    
    # 设备锁定
    paddle.set_device(config.device)
    paddle.set_num_threads(cpu_cores)
    paddle.set_num_interop_threads(cpu_cores)
    paddle.set_float32_matmul_precision("medium")
    
    # 固定随机种子
