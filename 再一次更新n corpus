# 断点保存函数，原子写入避免文件损坏
def save_checkpoint(config: EasyDict, model: nn.Layer, optimizer: paddle.optimizer.Optimizer, ema: Optional[EMA], tokenizer: GPTTokenizerManager, global_step: int, epoch: int, val_ppl: float, is_best: bool = False):
    checkpoint = {
        "config": dict(config),
        "model_state_dict": model.state_dict(),
        "optimizer_state_dict": optimizer.state_dict(),
        "ema_shadow": ema.shadow if ema is not None else None,
        "tokenizer_vocab_size": tokenizer.vocab_size,
        "global_step": global_step,
        "epoch": epoch,
        "val_ppl": val_ppl,
        "timestamp": datetime.now().isoformat()
    checkpoint = {
        "config": dict(config),
        "model_state_dict": model.state_dict(),
        "optimizer_state_dict": optimizer.state_dict(),
        "ema_shadow": ema.shadow if ema is not None else None,
        "tokenizer_vocab_size": tokenizer.vocab_size,
        "global_step": global_step,
        "epoch": epoch,
        "val_ppl": val_ppl,
        "timestamp": datetime.now().isoformat()
    }
    # 原子写入避免文件损坏
    temp_path = os.path.join(config.checkpoint_dir, "temp_checkpoint.pdparams")
    latest_path = os.path.join(config.checkpoint_dir, "latest_checkpoint.pdparams")
    paddle.save(checkpoint, temp_path)
    if os.path.exists(latest_path):
        os.replace(temp_path, latest_path)
    else:
        os.rename(temp_path, latest_path)
    LOGGER.info(f"断点保存完成，步数：{global_step}")
    # 保存最优模型
    if is_best:
        best_path = os.path.join(config.checkpoint_dir, "best_checkpoint.pdparams")
        shutil.copyfile(latest_path, best_path)
        LOGGER.info(f"最优模型更新，验证PPL：{val_ppl:.4f}")
    # 保存到wandb artifacts
    if config.enable_wandb and WANDB_AVAILABLE and config.wandb_save_artifact:
        artifact = wandb.Artifact(f"gpt_model_step_{global_step}", type="model")
        artifact.add_file(latest_path)
        wandb.log_artifact(artifact)

# 断点加载函数，支持断点续训
def load_checkpoint(config: EasyDict, model: nn.Layer, optimizer: paddle.optimizer.Optimizer, ema: Optional[EMA]) -> Tuple[int, int, float]:
    latest_path = os.path.join(config.checkpoint_dir, "latest_checkpoint.pdparams")
    if not os.path.exists(latest_path) or not config.enable_auto_resume:
        LOGGER.info("未找到断点，从头开始训练")
        return 0, 0, float("inf")
    LOGGER.info(f"加载断点：{latest_path}")
    checkpoint = paddle.load(latest_path)
    model.set_state_dict(checkpoint["model_state_dict"])
    optimizer.set_state_dict(checkpoint["optimizer_state_dict"])
    if ema is not None and checkpoint["ema_shadow"] is not None:
        ema.shadow = checkpoint["ema_shadow"]
    global_step = checkpoint["global_step"]
    start_epoch = checkpoint["epoch"]
    best_val_ppl = checkpoint["val_ppl"]
    LOGGER.info(f"断点加载完成，起始步数：{global_step}，起始轮次：{start_epoch}")
    return global_step, start_epoch, best_val_ppl

# 模型评估函数，返回损失与困惑度PPL
def evaluate(model: nn.Layer, data_loader: DataLoader, vocab_size: int, ema: Optional[EMA] = None, max_batches: int = None) -> Tuple[float, float]:
    if ema is not None:
        ema.apply_shadow()
    model.eval()
    total_loss = 0.0
    total_samples = 0
    with paddle.no_grad():
        for batch_idx, (x, y) in enumerate(data_loader):
            if max_batches is not None and batch_idx >= max_batches:
                break
            logits, z_loss = model(x)
            ce_loss = F.cross_entropy(logits.reshape([-1, vocab_size]), y.reshape([-1]))
            batch_loss = (ce_loss + z_loss).numpy()[0]
            total_loss += batch_loss * len(x)
            total_samples += len(x)
    if ema is not None:
        ema.restore()
    avg_loss = total_loss / total_samples
    val_ppl = np.exp(avg_loss)
    model.train()
    return avg_loss, val_ppl

# 嵌入层预热函数，稳定训练初期
def embedding_warmup_stage(model: GPTBackbone, train_loader: DataLoader, config: EasyDict, tokenizer: GPTTokenizerManager) -> GPTBackbone:
    if not config.enable_embedding_warmup:
        LOGGER.info("跳过嵌入层预热")
        return model
    # 计算预热步数
    total_train_samples = len(train_loader.dataset)
    warmup_steps = int(total_train_samples * config.embedding_warmup_steps_ratio)
    warmup_steps = max(100, warmup_steps)
    LOGGER.info(f"开始嵌入层预热，总步数：{warmup_steps}")
    # 冻结主干网络，只训练嵌入层和LM头
    for name, param in model.named_parameters():
        if "token_embedding" not in name and "lm_head" not in name:
            param.stop_gradient = True
        else:
            param.stop_gradient = False
    # 预热阶段优化器
    warmup_optimizer = paddle.optimizer.AdamW(
        parameters=[p for p in model.parameters() if not p.stop_gradient],
        learning_rate=config.embedding_warmup_lr,
        beta1=0.9,
        beta2=0.95,
        epsilon=1e-8,
        weight_decay=0.0
    )
    # 预热训练循环
    model.train()
    progress_bar = tqdm(range(warmup_steps), desc="嵌入层预热")
    train_iter = iter(train_loader)
    for step in progress_bar:
        try:
            x, y = next(train_iter)
        except StopIteration:
            train_iter = iter(train_loader)
            x, y = next(train_iter)
        # 前向传播
        logits, z_loss = model(x)
        ce_loss = F.cross_entropy(logits.reshape([-1, tokenizer.vocab_size]), y.reshape([-1]))
        total_loss = ce_loss + z_loss
        # 反向传播
        total_loss.backward()
        warmup_optimizer.step()
        warmup_optimizer.clear_grad()
        # 日志记录
        if step % config.log_interval == 0:
            train_ppl = np.exp(ce_loss.numpy()[0])
            metrics = {
                "ce_loss": ce_loss.numpy()[0].item(),
                "total_loss": total_loss.numpy()[0].item(),
                "train_ppl": train_ppl.item()
            }
            WARMUP_METRIC_MANAGER.log_metrics(step, 0, metrics, is_warmup=True)
            progress_bar.set_postfix({"loss": f"{total_loss.numpy()[0]:.4f}", "ppl": f"{train_ppl:.2f}"})
    # 解冻所有参数
    for param in model.parameters():
        param.stop_gradient = False
    LOGGER.info("嵌入层预热完成，所有参数已解冻")
    return model

# ====================================== 主训练流程 ======================================
def main():
    # wandb初始化
    if CONFIG.enable_wandb and WANDB_AVAILABLE:
        wandb.init(
            project=CONFIG.wandb_project,
            entity=CONFIG.wandb_entity,
            name=CONFIG.wandb_run_name,
            config=dict(CONFIG),
            mode="offline" if CONFIG.wandb_offline else "online"
        )
        LOGGER.info(f"wandb初始化完成，运行ID：{wandb.run.id}")

    # 1. 语料加载与清洗
    LOGGER.info("="*100)
    LOGGER.info("第一步：语料加载与清洗")
    LOGGER.info("="*100)
    corpus_loader = CorpusLoader(CONFIG, LOGGER)
    raw_texts = corpus_loader.load_all_corpus()
    corpus_cleaner = CorpusCleaner(CONFIG, LOGGER)
    cleaned_texts = corpus_cleaner.clean_full_corpus(raw_texts)
    if len(cleaned_texts) == 0:
        LOGGER.error("无有效语料，训练终止")
        return

    # 2. 分词器训练
    LOGGER.info("="*100)
    LOGGER.info("第二步：训练BPE分词器")
    LOGGER.info("="*100)
    tokenizer = GPTTokenizerManager(CONFIG, LOGGER)
    if not os.path.exists(tokenizer.model_path):
        tokenizer.train(cleaned_texts)

    # 3. 数据集构建
    LOGGER.info("="*100)
    LOGGER.info("第三步：构建Token缓存与数据集")
    LOGGER.info("="*100)
    token_cache = TokenCacheManager(CONFIG, tokenizer, LOGGER)
    train_cache_path, val_cache_path, test_cache_path = token_cache.build_token_cache(cleaned_texts)
    # 加载Token流
    train_tokens = token_cache.load_train_tokens()
    val_tokens = token_cache.load_val_tokens()
    test_tokens = token_cache.load_test_tokens()
    # 构建数据集与DataLoader
    train_dataset = StreamingPretrainDataset(train_tokens, CONFIG.max_seq_len, tokenizer.eos_id, CONFIG, is_validation=False)
    val_dataset = StreamingPretrainDataset(val_tokens, CONFIG.max_seq_len, tokenizer.eos_id, CONFIG, is_validation=True)
    test_dataset = StreamingPretrainDataset(test_tokens, CONFIG.max_seq_len, tokenizer.eos_id, CONFIG, is_validation=True)
    train_loader = DataLoader(
        train_dataset,
        batch_size=CONFIG.batch_size_per_step,
        num_workers=max(1, CONFIG.physical_cpu_cores//2),
        prefetch_factor=4,
        drop_last=True
    )
    val_loader = DataLoader(
        val_dataset,
        batch_size=CONFIG.batch_size_per_step,
        num_workers=max(1, CONFIG.physical_cpu_cores//4),
        prefetch_factor=2,
        drop_last=False
    )
    test_loader = DataLoader(
        test_dataset,
        batch_size=CONFIG.batch_size_per_step,
        num_workers=max(1, CONFIG.physical_cpu_cores//4),
        prefetch_factor=2,
        drop_last=False
    )
    # 计算训练总步数
    steps_per_epoch = len(train_loader) // CONFIG.gradient_accumulation_steps
    total_train_steps = steps_per_epoch * CONFIG.max_epochs
    warmup_steps = int(total_train_steps * CONFIG.warmup_steps_ratio)
    LOGGER.info(f"训练总轮数：{CONFIG.max_epochs}轮，总步数：{total_train_steps}，预热步数：{warmup_steps}")

    # 4. 模型初始化
    LOGGER.info("="*100)
    LOGGER.info("第四步：初始化GPT模型")
    LOGGER.info("="*100)
    model = GPTBackbone(CONFIG, tokenizer.vocab_size)
    total_params = sum(p.numel() for p in model.parameters())
    LOGGER.info(f"模型初始化完成，总参数量：{total_params/1e6:.2f}M")

    # 5. 嵌入层预热
    LOGGER.info("="*100)
    LOGGER.info("第五步：嵌入层预热")
    LOGGER.info("="*100)
    model = embedding_warmup_stage(model, train_loader, CONFIG, tokenizer)

    # 6. 训练组件初始化
    # 优化器参数分组
    param_groups = get_layer_wise_weight_decay_params(model, CONFIG)
    # 优化器
    optimizer = paddle.optimizer.AdamW(
        parameters=param_groups,
        learning_rate=CONFIG.base_lr,
        beta1=0.9,
        beta2=0.95,
        epsilon=1e-8,
        grad_clip=nn.ClipGradByGlobalNorm(CONFIG.max_grad_norm) if CONFIG.enable_grad_clip else None
    )
    # EMA初始化
    ema = EMA(model, CONFIG.ema_decay) if CONFIG.enable_ema else None
    # 梯度噪声注入器
    grad_noise_injector = GradientNoiseInjector(CONFIG.grad_noise_eta, CONFIG.grad_noise_gamma)

    # 加载断点续训
    global_step, start_epoch, best_val_ppl = load_checkpoint(CONFIG, model, optimizer, ema)
    # 训练全局变量
    train_loss_accum = 0.0
    grad_step_count = 0
    early_stop_counter = 0

    # 7. 正式训练主循环
    LOGGER.info("="*100)
    LOGGER.info("开始正式预训练主循环")
    LOGGER.info("="*100)
    for epoch in range(start_epoch, CONFIG.max_epochs):
        model.train()
        epoch_bar = tqdm(train_loader, desc=f"Epoch [{epoch+1}/{CONFIG.max_epochs}]")
        for batch_idx, (x, y) in enumerate(epoch_bar):
            # 更新学习率
            current_lr = get_lr(global_step, total_train_steps, warmup_steps, CONFIG.base_lr, CONFIG.min_lr)
            optimizer.set_lr(current_lr)

            # 前向传播
            logits, z_loss = model(x)
            ce_loss = F.cross_entropy(logits.reshape([-1, tokenizer.vocab_size]), y.reshape([-1]))
            loss = ce_loss + z_loss

            # R-Drop正则
            if CONFIG.enable_r_drop:
                logits2, _ = model(x)
                rd_loss = r_drop_loss(logits, logits2, CONFIG.r_drop_alpha)
                loss = loss + rd_loss

            # 梯度累积
            loss = loss / CONFIG.gradient_accumulation_steps
            loss.backward()

            train_loss_accum += loss.numpy()[0]
            grad_step_count += 1

            # 达到累积步数更新参数
            if grad_step_count % CONFIG.gradient_accumulation_steps == 0:
                # 梯度噪声注入
                if CONFIG.enable_grad_noise_injection:
                    grad_noise_injector.inject(optimizer._parameter_list, global_step)

                optimizer.step()
                optimizer.clear_grad()

                # EMA更新
                if ema is not None:
                    ema.update()

                global_step += 1
                avg_train_loss = train_loss_accum / CONFIG.gradient_accumulation_steps
                train_ppl = np.exp(avg_train_loss)

                # 日志打印
                if global_step % CONFIG.log_interval == 0:
                    metrics = {
                        "train_loss": avg_train_loss,
                        "train_ppl": train_ppl,
                        "lr": current_lr
                    }
                    TRAIN_METRIC_MANAGER.log_metrics(global_step, epoch+1, metrics)
                    epoch_bar.set_postfix({
                        "loss": f"{avg_train_loss:.4f}",
                        "ppl": f"{train_ppl:.2f}",
                        "lr": f"{current_lr:.6f}"
                    })

                # 验证集评估
                if global_step % CONFIG.val_interval == 0:
                    val_loss, val_ppl = evaluate(model, val_loader, tokenizer.vocab_size, ema, CONFIG.max_val_batches)
                    LOGGER.info(f"【验证】step:{global_step} | val_loss:{val_loss:.4f} | val_ppl:{val_ppl:.2f}")
                    val_metrics = {"val_loss": val_loss, "val_ppl": val_ppl}
                    TRAIN_METRIC_MANAGER.log_metrics(global_step, epoch+1, val_metrics)

                    # 保存最优模型 + 早停判断
                    if val_ppl < best_val_ppl - CONFIG.early_stop_min_delta:
                        best_val_ppl = val_ppl
                        early_stop_counter = 0
                        save_checkpoint(CONFIG, model, optimizer, ema, tokenizer, global_step, epoch+1, best_val_ppl, is_best=True)
                    else:
                        early_stop_counter += 1
                        LOGGER.info(f"早停计数器：{early_stop_counter}/{CONFIG.early_stop_patience}")
                        if early_stop_counter >= CONFIG.early_stop_patience:
                            LOGGER.info("验证集指标不再提升，触发早停，训练结束")
                            raise KeyboardInterrupt

                # 定期保存断点
                if global_step % CONFIG.save_interval == 0:
                    save_checkpoint(CONFIG, model, optimizer, ema, tokenizer, global_step, epoch+1, best_val_ppl, is_best=False)

                # 清空累积
                train_loss_accum = 0.0

    # 8. 训练结束后测试集评估
    LOGGER.info("="*100)
    LOGGER.info("训练完成，开始测试集最终评估")
    LOGGER.info("="*100)
    test_loss, test_ppl = evaluate(model, test_loader, tokenizer.vocab_size, ema, CONFIG.max_test_batches)
    LOGGER.info(f"【最终测试】test_loss:{test_loss:.4f} | test_ppl:{test_ppl:.2f}")
    TEST_METRIC_MANAGER.log_metrics(global_step, CONFIG.max_epochs, {"test_loss": test_loss, "test_ppl": test_ppl})

    # 保存最终完整模型
    paddle.save(model.state_dict(), CONFIG.final_model_save_path)
    LOGGER.info(f"最终模型已保存至：{CONFIG.final_model_save_path}")

    # 结束wandb
    if CONFIG.enable_wandb and WANDB_AVAILABLE:
        wandb.finish()

if __name__ == "__main__":
    try:
        main()
    except KeyboardInterrupt:
        LOGGER.info("训练被手动终止，正在保存当前断点...")
        save_checkpoint(CONFIG, model, optimizer, ema, tokenizer, global_step, start_epoch, best_val_ppl)
        LOGGER.info("断点保存成功，程序退出")
    except Exception as e:
        LOGGER.error(f"训练异常崩溃：{traceback.format_exc()}")
