# 多格式语料加载器
class CorpusLoader:
    SUPPORTED_EXTENSIONS = {".txt", ".jsonl", ".parquet"}
    def __init__(self, config: EasyDict, logger: logging.Logger):
        self.config = config
        self.logger = logger
        self.text_key = ["text", "content", "document", "paragraph", "article"]
        self.num_workers = max(1, config.physical_cpu_cores // 2)

    def _scan_corpus_files(self) -> List[str]:
        corpus_files = []
        for root, _, files in os.walk(self.config.corpus_dir):
            for file in files:
                file_ext = os.path.splitext(file)[1].lower()
                if file_ext in self.SUPPORTED_EXTENSIONS:
                    corpus_files.append(os.path.join(root, file))
        self.logger.info(f"扫描到语料文件：{len(corpus_files)}个")
        return corpus_files

    def _load_single_file(self, file_path: str) -> List[str]:
        file_ext = os.path.splitext(file_path)[1].lower()
        paragraphs = []
        try:
            if file_ext == ".txt":
                with open(file_path, "r", encoding="utf-8", errors="ignore") as f:
                    content = f.read()
                    paragraphs = [p.strip() for p in re.split(r'\n\s*\n', content) if len(p.strip()) > 20]
            elif file_ext == ".jsonl":
                with open(file_path, "r", encoding="utf-8", errors="ignore") as f:
                    for line in f:
                        line = line.strip()
                        if not line: continue
                        data = json.loads(line)
                        for key in self.text_key:
                            if key in data and isinstance(data[key], str):
                                text = data[key].strip()
                                if len(text) > 20:
                                    paragraphs.append(text)
                                break
            elif file_ext == ".parquet":
                parquet_file = pq.ParquetFile(file_path)
                for batch in parquet_file.iter_batches(batch_size=10000):
                    df = batch.to_pandas()
                    for col in df.columns:
                        if col.lower() in self.text_key:
                            texts = df[col].dropna().astype(str).tolist()
                            paragraphs.extend([t.strip() for t in texts if len(t.strip()) > 20])
                            break
            return paragraphs
        except Exception as e:
            self.logger.error(f"文件加载失败：{file_path}，错误：{str(e)}")
            return []

    def load_all_corpus(self) -> List[str]:
        corpus_files = self._scan_corpus_files()
        if len(corpus_files) == 0:
            raise FileNotFoundError(f"语料目录{self.config.corpus_dir}中无有效文件")
        with Pool(self.num_workers) as pool:
            results = list(tqdm(pool.imap(self._load_single_file, corpus_files), total=len(corpus_files), desc="语料加载"))
            pool.close()
            pool.join()
        all_paragraphs = []
        for res in results:
            all_paragraphs.extend(res)
        self.logger.info(f"语料加载完成，总段落数：{len(all_paragraphs)}")
        return all_paragraphs

# 语料清洗器
class CorpusCleaner:
    def __init__(self, config: EasyDict, logger: logging.Logger):
        self.config = config
        self.logger = logger
        self.min_text_length = config.min_text_length
        self.max_text_length = config.max_text_length
        self.support_languages = ["zh", "en", "ja", "ko"]
        # 清洗正则规则
        self.html_re = re.compile(r'<[^>]+>', re.S)
        self.url_re = re.compile(r'https?://\S+|www.\S+', re.S)
        self.duplicate_punct_re = re.compile(r'([。！？，；：.!?,;])\1+', re.S)
        self.whitespace_re = re.compile(r'\s+', re.S)
        self.invalid_char_re = re.compile(r'[\x00-\x08\x0b\x0c\x0e-\x1f\x7f]', re.S)

    def clean_single_text(self, text: str) -> Tuple[bool, str]:
        try:
            # 基础字符清洗
            text = text.replace('\u3000',' ').replace('\u200B','')
            text = self.invalid_char_re.sub('', text)
            text = self.html_re.sub('', text)
            text = self.url_re.sub('', text)
            text = self.duplicate_punct_re.sub(r'\1', text)
            text = self.whitespace_re.sub(' ', text)
            text = text.strip()
            # 长度过滤
            if len(text) < self.min_text_length or len(text) > self.max_text_length:
                return False, "长度不符合"
            # 语言过滤
            try:
                lang = langdetect.detect(text)
                if lang not in self.support_languages:
                    return False, "非支持语言"
            except LangDetectException:
                return False, "语言检测失败"
            return True, text
        except Exception as e:
            return False, f"清洗异常：{str(e)}"

    def deduplicate_corpus(self, texts: List[str]) -> List[str]:
        # 精确去重
        seen_hash = set()
        unique_texts = []
        for text in tqdm(texts, desc="精确去重"):
            text_hash = hashlib.sha256(text.encode("utf-8")).hexdigest()
            if text_hash not in seen_hash:
                seen_hash.add(text_hash)
                unique_texts.append(text)
        self.logger.info(f"精确去重完成：{len(texts)} → {len(unique_texts)}")
        # Simhash模糊去重
        final_texts = []
        simhash_index = SimhashIndex([], k=3)
        for idx, text in enumerate(tqdm(unique_texts, desc="模糊去重")):
            sim_hash = Simhash(text)
            if not simhash_index.get_near_dups(sim_hash):
                simhash_index.add(f"text_{idx}", sim_hash)
                final_texts.append(text)
        self.logger.info(f"模糊去重完成：{len(unique_texts)} → {len(final_texts)}")
        return final_texts

    def clean_full_corpus(self, texts: List[str]) -> List[str]:
        with Pool(max(1, self.config.physical_cpu_cores//2)) as pool:
            results = list(tqdm(pool.imap(self.clean_single_text, texts), total=len(texts), desc="语料清洗"))
            pool.close()
            pool.join()
        valid_texts = [cleaned for is_valid, cleaned in results if is_valid]
        self.logger.info(f"清洗完成，有效文本数：{len(valid_texts)}")
        return self.deduplicate_corpus(valid_texts)

# BPE分词器管理器
class GPTTokenizerManager:
    def __init__(self, config: EasyDict, logger: logging.Logger):
        self.config = config
        self.logger = logger
        self.model_path = os.path.join(config.tokenizer_dir, "gpt_bpe.model")
        self.sp = None
        # 特殊Token定义
        self.special_tokens = {"<s>": 0, "</s>": 1, "<pad>": 2, "<unk>": 3}
        self.bos_id = self.special_tokens["<s>"]
        self.eos_id = self.special_tokens["</s>"]
        self.pad_id = self.special_tokens["<pad>"]
        self.unk_id = self.special_tokens["<unk>"]
        # 加载已有模型
        if os.path.exists(self.model_path):
            self.load()

    def train(self, corpus_texts: List[str]):
        self.logger.info("开始训练BPE分词器")
        corpus_file = os.path.join(self.config.preprocessed_data_dir, "tokenizer_train_corpus.txt")
        with open(corpus_file, "w", encoding="utf-8") as f:
            for text in tqdm(corpus_texts, desc="生成分词器训练语料"):
                f.write(text + "\n")
        # 训练BPE模型
        spm.SentencePieceTrainer.train(
            input=corpus_file,
            model_prefix=os.path.join(self.config.tokenizer_dir, "gpt_bpe"),
            vocab_size=self.config.vocab_size,
            character_coverage=self.config.character_coverage,
            model_type="bpe",
            bos_id=self.bos_id,
            eos_id=self.eos_id,
            pad_id=self.pad_id,
            unk_id=self.unk_id,
            bos_piece="<s>",
            eos_piece="</s>",
            pad_piece="<pad>",
            unk_piece="<unk>",
            byte_fallback=True,
            split_digits=True,
            num_threads=self.config.physical_cpu_cores,
            hard_vocab_limit=False
        )
        self.load()
        self.logger.info(f"分词器训练完成，词汇表大小：{self.vocab_size}")
        os.remove(corpus_file)

    def load(self):
        self.sp = spm.SentencePieceProcessor(model_file=self.model_path)
        assert self.sp.bos_id() == self.bos_id, "BOS ID不匹配"
        assert self.sp.eos_id() == self.eos_id, "EOS ID不匹配"

    @property
    def vocab_size(self) -> int:
        return self.sp.vocab_size()

    def encode(self, text: str, add_bos: bool = False, add_eos: bool = True) -> List[int]:
        ids = self.sp.encode(text, out_type=int)
        if add_bos:
            ids = [self.bos_id] + ids
        if add_eos:
            ids = ids + [self.eos_id]
        return ids

    def decode(self, ids: List[int], skip_special_tokens: bool = True) -> str:
        if skip_special_tokens:
            ids = [i for i in ids if i not in [self.bos_id, self.eos_id, self.pad_id]]
        return self.sp.decode(ids)

# Token缓存与流式数据集管理器
class TokenCacheManager:
    def __init__(self, config: EasyDict, tokenizer: GPTTokenizerManager, logger: logging.Logger):
        self.config = config
        self.tokenizer = tokenizer
        self.logger = logger
        self.max_seq_len = config.max_seq_len
        self.cache_dir = config.preprocessed_data_dir
        self.train_cache_path = os.path.join(self.cache_dir, "train_tokens.npy")
        self.val_cache_path = os.path.join(self.cache_dir, "val_tokens.npy")
        self.test_cache_path = os.path.join(self.cache_dir, "test_tokens.npy")
        self.meta_path = os.path.join(self.cache_dir, "meta.json")

    def process_corpus_to_token_stream(self, cleaned_texts: List[str]) -> np.ndarray:
        all_doc_tokens = []
        for doc in tqdm(cleaned_texts, desc="文档分词"):
            doc_tokens = self.tokenizer.encode(doc, add_bos=False, add_eos=True)
            if len(doc_tokens) >= 10:
                all_doc_tokens.extend(doc_tokens)
        self.logger.info(f"Token流构建完成，总token数：{len(all_doc_tokens)}")
        return np.array(all_doc_tokens, dtype=np.int64)

    def build_token_cache(self, cleaned_texts: List[str]) -> Tuple[str, str, str]:
        if self.is_cache_valid():
            self.logger.info("Token缓存有效，直接复用")
            return self.train_cache_path, self.val_cache_path, self.test_cache_path
        # 处理全量语料为token流
        all_tokens = self.process_corpus_to_token_stream(cleaned_texts)
        if len(all_tokens) < self.max_seq_len * 100:
            raise ValueError(f"有效token数不足，无法训练")
        # 训练/验证/测试集划分
        total_len = len(all_tokens)
        train_split = int(total_len * self.config.train_ratio)
        val_split = int(total_len * (self.config.train_ratio + self.config.val_ratio))
        train_tokens = all_tokens[:train_split]
        val_tokens = all_tokens[train_split:val_split]
        test_tokens = all_tokens[val_split:]
        # 保存缓存文件
        np.save(self.train_cache_path, train_tokens)
        np.save(self.val_cache_path, val_tokens)
        np.save(self.test_cache_path, test_tokens)
        # 保存元数据
        meta = {"total_tokens": len(all_tokens), "train_tokens": len(train_tokens), "val_tokens": len(val_tokens), "test_tokens": len(test_tokens), "max_seq_len": self.max_seq_len, "vocab_size": self.tokenizer.vocab_size}
        with open(self.meta_path, "w", encoding="utf-8") as f:
            json.dump(meta, f, ensure_ascii=False, indent=2)
        self.logger.info(f"Token缓存构建完成，训练集{len(train_tokens)}token")
        return self.train_cache_path, self.val_cache_path, self.test_cache_path

    def is_cache_valid(self) -> bool:
        if not all([os.path.exists(p) for p in [self.train_cache_path, self.val_cache_path, self.test_cache_path, self.meta_path]]):
            return False
        try:
            with open(self.meta_path, "r", encoding="utf-8") as f:
                meta = json.load(f)
            return meta["max_seq_len"] == self.max_seq_len and meta["vocab_size"] == self.tokenizer.vocab_size
        except:
            return False

    def load_train_tokens(self) -> np.ndarray:
        return np.load(self.train_cache_path, mmap_mode="r" if self.config.enable_mmap_token else None)

    def load_val_tokens(self) -> np.ndarray:
        return np.load(self.val_cache_path, mmap_mode="r" if self.config.enable_mmap_token else None)

    def load_test_tokens(self) -> np.ndarray:
        return np.load(self.test_cache_path, mmap_mode="r" if self.config.enable_mmap_token else None)

# 流式预训练数据集，内存友好型
class StreamingPretrainDataset(IterableDataset):
    def __init__(self, token_array: np.ndarray, max_seq_len: int, eos_id: int, config: EasyDict, is_validation: bool = False):
        super().__init__()
        self.token_array = token_array
        self.max_seq_len = max_seq_len
        self.eos_id = eos_id
        self.config = config
        self.is_validation = is_validation
        self.chunk_size = max_seq_len + 1
        self.doc_boundaries = np.where(self.token_array == eos_id)[0] + 1

    def __iter__(self) -> Generator[Tuple[paddle.Tensor, paddle.Tensor], None, None]:
        total_length = len(self.token_array)
        current_idx = 0 if self.is_validation else random.randint(0, self.chunk_size // 2)
        while current_idx + self.chunk_size < total_length:
            # 文档边界感知切分，避免跨文档伪关联
            if self.config.doc_boundary_aware:
                boundary_in_chunk = self.doc_boundaries[(self.doc_boundaries > current_idx) & (self.doc_boundaries < current_idx + self.chunk_size)]
                if len(boundary_in_chunk) > 0:
                    current_idx = boundary_in_chunk[-1]
                    if current_idx + self.chunk_size >= total_length:
                        break
            # 构建自回归输入与目标
            end_idx = current_idx + self.chunk_size
            token_chunk = self.token_array[current_idx:end_idx]
            input_ids = token_chunk[:-1]
            target_ids = token_chunk[1:]
            yield (paddle.to_tensor(input_ids, dtype=paddle.int64), paddle.to_tensor(target_ids, dtype=paddle.int64))
            current_idx += self.chunk_size - 1

    def __len__(self) -> int:
        return len(self.token_array) // (self.chunk_size - 1)

