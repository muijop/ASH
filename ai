    trainable_params = [p for p in model.parameters() if p.requires_grad]可训练参数 = [p for p in 模型参数 if p.requires_grad]
    optimizer = SophiaH(trainable_params, lr=BASE_LR, weight_decay=WEIGHT_DECAY)
