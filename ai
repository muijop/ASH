    model, optimizer, scheduler, start_corpus_idx, start_epoch, global_step, best_ppl = load_checkpoint(model, optimizer, scheduler)

    # 6. 顺序训练所有语料
    for corpus_idx in range(start_corpus_idx, total_corpus):
        corpus_path = corpus_list[corpus_idx]
        # 跳过已训完的语料
        if os.path.exists(os.path.join(MODEL_SAVE_DIR, f"model_{os.path.basename(corpus_path)}.pth")):
            write_log(f"{os.path.basename(corpus_path)} 已训练完成，自动跳过")
            continue
        model, optimizer, scheduler, global_step = train_single_corpus(
            model, optimizer, scheduler, tokenizer, corpus_path, corpus_idx, total_corpus, global_step
        )

    # 全部训完保存最终模型
    torch.save(model.state_dict(), FINAL_MODEL_PATH)
    # 删除临时断点
    if os.path.exists(TEMP_CKPT_PATH):
        os.remove(TEMP_CKPT_PATH)
    write_log("\n======== 所有语料训练全部结束，最终模型已保存 =========")

