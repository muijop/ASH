# ===================== 模型核心模块 =====================
# 归一化层
class RMSNorm(nn.Module):
    def __init__(self, dim: int, eps: float = 1e-6):
        super().__init__()
        self.eps = eps
        self.weight = nn.Parameter(torch.ones(dim))

    def forward(self, x: torch.Tensor):
        return x * torch.rsqrt(x.pow(2).mean(-1, keepdim=True) + self.eps) * self.weight

# 旋转位置编码 RoPE
class RoPE(nn.Module):
    def __init__(self, head_dim: int, max_seq_len: int, base: int = 10000):
        super().__init__()
        theta = 1.0 / (base ** (torch.arange(0, head_dim, 2).float() / head_dim))
        seq_idx = torch.arange(max_seq_len).float()
        freqs = torch.outer(seq_idx, theta)
        self.register_buffer("cos", freqs.cos()[None, None, :, :])
        self.register_buffer("sin", freqs.sin()[None, None, :, :])

    def forward(self, x: torch.Tensor):
        seq_len = x.shape[2]
        cos = self.cos[:, :, :seq_len, :].to(x.dtype)
        sin = self.sin[:, :, :seq_len, :].to(x.dtype)
        x1, x2 = x.chunk(2, dim=-1)
        return torch.cat([x1 * cos - x2 * sin, x1 * sin + x2 * cos], dim=-1)

# 分组查询注意力 GQA
class GQAAttention(nn.Module):
    def __init__(self):
        super().__init__()
        self.head_dim = EMBED_DIM // NUM_Q_HEADS
        self.num_q_heads = NUM_Q_HEADS
        self.num_kv_heads = NUM_KV_HEADS
        self.kv_repeat = self.num_q_heads // self.num_kv_heads

        self.q_proj = nn.Linear(EMBED_DIM, self.num_q_heads * self.head_dim, bias=False)
        self.k_proj = nn.Linear(EMBED_DIM, self.num_kv_heads * self.head_dim, bias=False)
        self.v_proj = nn.Linear(EMBED_DIM, self.num_kv_heads * self.head_dim, bias=False)
        self.out_proj = nn.Linear(EMBED_DIM, EMBED_DIM, bias=False)

        self.rope = RoPE(self.head_dim, MAX_SEQ_LEN)
        self.register_buffer("causal_mask", torch.tril(torch.ones(1, 1, MAX_SEQ_LEN, MAX_SEQ_LEN)))

    def forward(self, x: torch.Tensor):
        batch_size, seq_len, _ = x.shape
        q = self.q_proj(x).view(batch_size, seq_len, self.num_q_heads, self.head_dim).transpose(1, 2)
        k = self.k_proj(x).view(batch_size, seq_len, self.num_kv_heads, self.head_dim).transpose(1, 2)
        v = self.v_proj(x).view(batch_size, seq_len, self.num_kv_heads, self.head_dim).transpose(1, 2)

        q = self.rope(q)
        k = self.rope(k)

        k = k.repeat_interleave(self.kv_repeat, dim=1)
        v = v.repeat_interleave(self.kv_repeat, dim=1)

        attn_scores = (q @ k.transpose(-2, -1)) / (self.head_dim ** 0.5)
        attn_scores = attn_scores.masked_fill(self.causal_mask[:, :, :seq_len, :seq_len] == 0, float("-inf"))

        # 稀疏优化，降低CPU计算量
        top_k = min(32, seq_len)
        top_k_values, _ = torch.topk(attn_scores, top_k, dim=-1)
        attn_scores = attn_scores.masked_fill(attn_scores < top_k_values[..., -1, None], float("-inf"))

        attn_weights = F.softmax(attn_scores, dim=-1)
        attn_output = (attn_weights @ v).transpose(1, 2).contiguous().view(batch_size, seq_len, EMBED_DIM)
        return self.out_proj(attn_output)

# SwiGLU 前馈网络
class SwiGLUFFN(nn.Module):
    def __init__(self):
        super().__init__()
        hidden_dim = int(EMBED_DIM * FFN_EXPANSION_RATIO)
        self.w1 = nn.Linear(EMBED_DIM, hidden_dim, bias=False)
        self.w2 = nn.Linear(hidden_dim, EMBED_DIM, bias=False)
        self.w3 = nn.Linear(EMBED_DIM, hidden_dim, bias=False)

    def forward(self, x: torch.Tensor):
        return self.w2(F.silu(self.w1(x)) * self.w3(x))

# ===================== 2026最新Block级超残差连接Decoder层 =====================
class HyperResDecoderLayer(nn.Module):
    def __init__(self, is_trainable: bool = True):
        super().__init__()
        self.attn_norm = RMSNorm(EMBED_DIM)
        self.attn = GQAAttention()
        self.ffn_norm = RMSNorm(EMBED_DIM)
        self.ffn = SwiGLUFFN()
        
        # 局部残差可学习缩放系数
        self.res_scale = nn.Parameter(torch.ones(1) * 0.1)
        # 层是否可训练
        self.is_trainable = is_trainable
        if not is_trainable:
            for param in self.parameters():
                param.requires_grad = False

    def forward(self, x: torch.Tensor):
        if self.is_trainable:
            # 标准局部残差连接
            attn_out = x + self.attn(self.attn_norm(x)) * self.res_scale
            ffn_out = attn_out + self.ffn(self.ffn_norm(attn_out)) * self.res_scale
        else:
            with torch.no_grad():
                attn_out = x + self.attn(self.attn_norm(x)) * self.res_scale
                ffn_out = attn_out + self.ffn(self.ffn_norm(attn_out)) * self.res_scale
        return ffn_out

# ===================== 完整大语言模型（带全局超残差连接） =====================
class HyperResLLModel(nn.Module):
    def __init__(self, trainable_layers: list = None):
        super().__init__()
        self.token_embedding = nn.Embedding(VOCAB_SIZE, EMBED_DIM)
        
        # 动态设置可训练层
        if trainable_layers is None:
            trainable_layers = list(range(NUM_LAYERS))
        self.decoder_layers = nn.ModuleList([
            HyperResDecoderLayer(is_trainable=(i in trainable_layers))
            for i in range(NUM_LAYERS)
        ])
        
        self.final_norm = RMSNorm(EMBED_DIM)
        self.lm_head = nn.Linear(EMBED_DIM, VOCAB_SIZE, bias=False)
        # 权重共享，减少参数量
        self.token_embedding.weight = self.lm_head.weight

    def forward(self, input_ids: torch.Tensor):
        x = self.token_embedding(input_ids)
        # 全局超残差连接：每2层传递一次全局残差信号
        global_res = x
        for idx, layer in enumerate(self.decoder_layers):
            x = layer(x)
            # 每2层注入一次全局残差，解决信息稀释问题
            if (idx + 1) % 2 == 0:
                x = x + global_res * 0.05
        x = self.final_norm(x)
        logits = self.lm_head(x)
        return logits

# ===================== 修正版 SophiaH 优化器 =====================
class SophiaH(torch.optim.Optimizer):
    def __init__(self, params, lr=1e-4, betas=(0.965, 0.99), rho=0.04, weight_decay=0.01, eps=1e-12):
        defaults = dict(lr=lr, betas=betas, rho=rho, weight_decay=weight_decay, eps=eps)
        super().__init__(params, defaults)

    @torch.no_grad()
    def step(self, hessian=None):
        for group in self.param_groups:
            for p in group['params']:
                if p.grad is None:
                    continue
                grad = p.grad
                state = self.state[p]

                if len(state) == 0:
                    state['step'] = 0
                    state['exp_avg'] = torch.zeros_like(p)
                    state['exp_avg_sq'] = torch.zeros_like(p)
                    state['hessian'] = torch.zeros_like(p)

                exp_avg, exp_avg_sq, hessian_est = state['exp_avg'], state['exp_avg_sq'], state['hessian']
                beta1, beta2 = group['betas']
                rho = group['rho']
                lr = group['lr']
                weight_decay = group['weight_decay']

                state['step'] += 1
                exp_avg.mul_(beta1).add_(grad, alpha=1 - beta1)
                exp_avg_sq.mul_(beta2).addcmul_(grad, grad.conj(), value=1 - beta2)

                if weight_decay != 0:
                    p.mul_(1 - lr * weight_decay)

                if hessian is not None:
                    hessian_est.mul_(beta2).add_(hessian, alpha=1 - beta2)

                if state['step'] % 10 == 0 and hessian is not None:
                    update = exp_avg / (rho * torch.clamp(hessian_est, min=group['eps']) + group['eps'])
                else:
                    update = exp_avg / (torch.sqrt(exp_avg_sq) + group['eps'])

                p.add_(update, alpha=-lr)
        return

