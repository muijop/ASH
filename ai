# 自动扫描语料文件
def auto_scan_corpus():
    all_txt_files = glob.glob(os.path.join(CURRENT_DIR, "*.txt"))
    corpus_pattern = re.compile(r"^(\d+)\.txt$")
    corpus_list = []
    for file_path in all_txt_files:
        file_name = os.path.basename(file_path)
        match = corpus_pattern.match(file_name)
        if match:
            num = int(match.group(1))
            corpus_list.append((num, file_path))
    corpus_list.sort(key=lambda x: x[0])
    sorted_corpus = [x[1] for x in corpus_list]

    if len(sorted_corpus) == 0:
        raise FileNotFoundError("未找到 1.txt、2.txt 等数字命名的文本语料")

    write_log(f"检测到{len(sorted_corpus)}个语料文件，将按顺序依次训练：")
    for path in sorted_corpus:
        write_log("   " + os.path.basename(path))
    return sorted_corpus

# 加载/训练分词器
def get_tokenizer(corpus_list):
    if os.path.exists(TOKENIZER_MODEL_PATH):
        sp = spm.SentencePieceProcessor(model_file=TOKENIZER_MODEL_PATH)
        write_log("加载已存在的分词器")
        return sp
    else:
        write_log("初次运行，开始训练分词器")
        all_text = ""
        for path in corpus_list:
            with open(path, "r", encoding="utf-8", errors="ignore") as f:
                all_text += f.read() + "\n"
        temp_file = os.path.join(TOKENIZER_DIR, "temp.txt")
        with open(temp_file, "w", encoding="utf-8") as f:
            f.write(all_text)

        spm.SentencePieceTrainer.train(
            input=temp_file,
            model_prefix=os.path.join(TOKENIZER_DIR, "spm_tokenizer"),
            vocab_size=VOCAB_SIZE,
            character_coverage=0.9995,
            model_type="bpe"
        )
        os.remove(temp_file)
        sp = spm.SentencePieceProcessor(model_file=TOKENIZER_MODEL_PATH)
        write_log("分词器训练完成")
        return sp

# 语料清洗+训练集/验证集划分
def load_and_split_corpus(corpus_path, tokenizer, val_ratio=VAL_RATIO):
    # 读取并清洗语料
    with open(corpus_path, "r", encoding="utf-8", errors="ignore") as f:
        lines = f.readlines()
    valid_paragraphs = []
    para_set = set()
    current_para = ""
    for line in lines:
        line = line.strip()
        if len(line) == 0:
            if len(current_para) > 50 and current_para not in para_set:
                para_set.add(current_para)
                valid_paragraphs.append(current_para)
            current_para = ""
        else:
            current_para += line + " "
    if len(current_para) > 50 and current_para not in para_set:
        valid_paragraphs.append(current_para)
    
    if len(valid_paragraphs) == 0:
        raise ValueError(f"语料{os.path.basename(corpus_path)}无有效数据")
    
    # 按段落划分训练集和验证集，避免数据泄露
    random.shuffle(valid_paragraphs)
    split_idx = int(len(valid_paragraphs) * (1 - val_ratio))
    train_paras = valid_paragraphs[:split_idx]
    val_paras = valid_paragraphs[split_idx:]
    write_log(f"语料划分完成：训练集{len(train_paras)}段，验证集{len(val_paras)}段")

    # 转token张量
    def paras_to_tensor(paras):
        all_ids = []
        for para in paras:
            all_ids.extend(tokenizer.encode(para, out_type=int))
        chunks = []
        for i in range(0, len(all_ids)-MAX_SEQ_LEN, MAX_SEQ_LEN):
            chunk = all_ids[i:i+MAX_SEQ_LEN]
            if len(chunk) == MAX_SEQ_LEN:
                chunks.append(chunk)
        if not chunks:
            return None
        tensor = torch.tensor(chunks, dtype=torch.long)
        return tensor[:, :-1], tensor[:, 1:]
    
    train_data = paras_to_tensor(train_paras)
    val_data = paras_to_tensor(val_paras)
    return train_data, val_data

# 验证集评估函数
def evaluate(model, val_data):
    model.eval()
    total_loss = 0.0
    x_val, y_val = val_data
    val_loader = torch.utils.data.DataLoader(
        torch.utils.data.TensorDataset(x_val, y_val),
        batch_size=BATCH_SIZE, shuffle=False
    )
    with torch.no_grad():
        for x, y in val_loader:
            x, y = x.to(DEVICE), y.to(DEVICE)
            logits = model(x)
            loss = F.cross_entropy(logits.reshape(-1, VOCAB_SIZE), y.reshape(-1))
            total_loss += loss.item()
    avg_loss = total_loss / len(val_loader)
    ppl = torch.exp(torch.tensor(avg_loss)).item()
    model.train()
    return avg_loss, ppl

# 断点续训加载
def load_checkpoint(model, optimizer, scheduler):
    start_corpus_idx = 0
    start_epoch = 0
    global_step = 0
    best_ppl = float("inf")
    if os.path.exists(TEMP_CKPT_PATH):
        write_log("检测到断点，自动加载继续训练...")
        ckpt = torch.load(TEMP_CKPT_PATH, map_location=DEVICE, weights_only=False)
        model.load_state_dict(ckpt["model_state"])
        optimizer.load_state_dict(ckpt["optimizer_state"])
        scheduler.load_state_dict(ckpt["scheduler_state"])
        start_corpus_idx = ckpt["corpus_idx"]
        start_epoch = ckpt["epoch"]
        global_step = ckpt["global_step"]
        best_ppl = ckpt["best_ppl"]
        write_log(f"断点加载完成，从第{start_corpus_idx+1}个语料继续")
    return model, optimizer, scheduler, start_corpus_idx, start_epoch, global_step, best_ppl

# 断点保存
def save_checkpoint(model, optimizer, scheduler, corpus_idx, epoch, global_step, best_ppl):
    ckpt = {
        "model_state": model.state_dict(),
        "optimizer_state": optimizer.state_dict(),
        "scheduler_state": scheduler.state_dict(),
        "corpus_idx": corpus_idx,
        "epoch": epoch,
        "global_step": global_step,
        "best_ppl": best_ppl
    }
    torch.save(ckpt, TEMP_CKPT_PATH)

# ===================== 单语料训练主流程 =====================
def train_single_corpus(model, optimizer, scheduler, tokenizer, corpus_path, corpus_idx, total_corpus, global_step):
    name = os.path.basename(corpus_path)
    write_log(f"\n------ 开始训练第{corpus_idx+1}个语料：{name} ------")

    # 动态设置可训练层：第一个语料全参数训练，后续增量训练首尾4层
    if corpus_idx == 0:
        trainable_layers = list(range(NUM_LAYERS))
    else:
        trainable_layers = list(range(2)) + list(range(NUM_LAYERS-2, NUM_LAYERS))
    for i, layer in enumerate(model.decoder_layers):
        layer.is_trainable = (i in trainable_layers)
        for param in layer.parameters():
            param.requires_grad = (i in trainable_layers)
    trainable_params = [p for p in model.parameters() if p.requires_grad]
    write_log(f"当前可训练层数：{len(trainable_layers)}，可训练参数量：{sum(p.numel() for p in trainable_params)/1e6:.2f}M")

    # 加载并划分训练集/验证集
    train_data, val_data = load_and_split_corpus(corpus_path, tokenizer)
    if train_data is None or val_data is None:
        write_log(f"❌ {name} 无有效训练数据，跳过")
        return model, optimizer, scheduler, global_step

    train_dataset = torch.utils.data.TensorDataset(*train_data)
    train_loader = torch.utils.data.DataLoader(
        train_dataset, batch_size=BATCH_SIZE, shuffle=True,
        num_workers=min(4, os.cpu_count())
    )

    # 早停初始化
    best_ppl = float("inf")
    patience_counter = 0
    model.train()

    for epoch in range(MAX_EPOCHS_PER_CORPUS):
        epoch_loss = 0.0
        pbar = tqdm(train_loader, desc=f"Epoch {epoch+1}/{MAX_EPOCHS_PER_CORPUS}")

        for step, (x, y) in enumerate(pbar):
            x, y = x.to(DEVICE), y.to(DEVICE)
            optimizer.zero_grad()

            # 前向传播
            logits = model(x)
            # 主损失+Z-Loss稳定训练
            loss_token = F.cross_entropy(logits.reshape(-1, VOCAB_SIZE), y.reshape(-1), label_smoothing=0.05)
            z_loss = 1e-4 * logits.pow(2).mean()
            loss = loss_token + z_loss

            # 反向传播
            loss.backward()

            # 自适应梯度裁剪
            grad_norm = nn.utils.clip_grad_norm_(model.parameters(), MAX_GRAD_NORM)
            # Hessian估计
            hessian = torch.square(loss_token.grad) if (global_step % 10 == 0 and loss_token.grad is not None) else None
            # 优化器与学习率更新
            optimizer.step(hessian=hessian)
            scheduler.step()

            global_step += 1
            epoch_loss += loss.item()
            avg_loss = epoch_loss / (step + 1)
            pbar.set_postfix({"loss": round(avg_loss, 4), "grad_norm": round(grad_norm.item(), 4)})

        # 每轮结束验证集评估
        val_loss, val_ppl = evaluate(model, val_data)
        train_avg_loss = epoch_loss / len(train_loader)
        write_log(f"Epoch {epoch+1} 结束 | 训练Loss: {train_avg_loss:.6f} | 验证Loss: {val_loss:.6f} | 验证PPL: {val_ppl:.2f}")

        # 早停判断
        if val_ppl < best_ppl:
            best_ppl = val_ppl
            patience_counter = 0
            # 保存最优模型
            torch.save(model.state_dict(), os.path.join(MODEL_SAVE_DIR, f"best_model_{name}.pth"))
        else:
            patience_counter += 1
            write_log(f"验证PPL未下降，耐心值：{patience_counter}/{EARLY_STOP_PATIENCE}")

        # 达到最小轮数后触发早停
        if epoch >= MIN_EPOCHS_PER_CORPUS and patience_counter >= EARLY_STOP_PATIENCE:
            write_log(f"触发早停，停止训练{name}")
            break

        # 保存断点
        save_checkpoint(model, optimizer, scheduler, corpus_idx, epoch+1, global_step, best_ppl)

    # 语料训完保存最终模型
    torch.save(model.state_dict(), os.path.join(MODEL_SAVE_DIR, f"model_{name}.pth"))
    write_log(f"{name} 训练完成，最优验证PPL: {best_ppl:.2f}，模型已保存")
    return model, optimizer, scheduler, global_step

