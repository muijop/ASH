# ====================================== 4. 日志与指标管理（严格遵循要求：终端仅显示进度，全量指标归档文件） ======================================
def setup_file_only_logger(config: EasyDict) -> logging.Logger:
    """
    严格遵循要求：
    1. 终端仅显示ERROR级别错误，不打印任何训练日志
    2. 全量INFO/DEBUG日志全部写入轮转日志文件
    3. 所有训练指标结构化归档到jsonl文件
    """
    log_file = os.path.join(config.log_dir, "train_full.log")
    logger = logging.getLogger("llm_pretrain")
    logger.setLevel(logging.DEBUG)
    logger.propagate = False
    
    # 清空已有handler
    if logger.handlers:
        logger.handlers.clear()
    
    # 日志格式
    log_format = logging.Formatter(
        "[%(asctime)s] [%(levelname)s] [%(filename)s:%(lineno)d] %(message)s",
        datefmt="%Y-%m-%d %H:%M:%S"
    )
    
    # 控制台handler：仅输出ERROR级别错误，不打印训练信息
    console_handler = logging.StreamHandler()
    console_handler.setLevel(logging.ERROR)
    console_handler.setFormatter(log_format)
    logger.addHandler(console_handler)
    
    # 文件handler：全量日志写入，支持轮转
    file_handler = RotatingFileHandler(
        log_file, maxBytes=200*1024*1024, backupCount=20, encoding="utf-8"
    )
    file_handler.setLevel(logging.DEBUG)
    file_handler.setFormatter(log_format)
    logger.addHandler(file_handler)
    
    # 启动日志
    logger.info("="*100)
    logger.info(f"大模型预训练启动时间：{datetime.now().strftime('%Y-%m-%d %H:%M:%S')}")
    logger.info(f"硬件环境：{CONFIG.physical_cpu_cores}核CPU，MKL-DNN={'开启' if CONFIG.enable_mkldnn else '关闭'}")
    logger.info(f"全量配置参数：{json.dumps(dict(config), ensure_ascii=False, indent=2)}")
    logger.info("="*100)
    
    return logger

class MetricManager:
    """结构化指标管理，所有训练指标全部写入jsonl文件，终端不显示"""
    def __init__(self, metric_file: str, logger: logging.Logger):
        self.metric_file = metric_file
        self.logger = logger
        # 初始化文件
        if not os.path.exists(metric_file):
            with open(metric_file, "w", encoding="utf-8") as f:
                f.write("")
    
    def log_metrics(self, step: int, epoch: int, metrics: Dict):
        """写入指标到文件，带时间戳"""
        metric_data = {
            "timestamp": datetime.now().isoformat(),
            "step": step,
            "epoch": epoch,
            **metrics
        }
        try:
            with open(self.metric_file, "a", encoding="utf-8") as f:
                f.write(json.dumps(metric_data, ensure_ascii=False) + "\n")
        except Exception as e:
            self.logger.error(f"指标写入失败：{str(e)}")

# 初始化日志与指标管理器
